      <xsd:element name="Section_H" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation source="FieldText">
            <d:b>H. DOMESTIC HOT WATER CONTROLS - <d:t24refnolink/>110.3, <d:t24refnolink/>120.9, <d:t24refnolink/>160.4(d), <d:t24refnolink/>170.2(d), <d:t24refnolink/>180.1(b)3 </d:b>
          </xsd:documentation>
          <xsd:documentation source="CalculationsAndRules">Section H is required if any row in section B has B03cNew_ProjectHasControls == true Or B03cAltered_ProjectHasControls == true
 
Mandatory Measure Triggers:
If this section is required    
MM110_3a1_MeasureApplies  = true and is displayed
End If</xsd:documentation>
          <xsd:documentation source="MinOccurs">If this section doesn't apply, do not display anything for this section</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="H_BeginNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i>This table is used to demonstrate compliance with control requirements in <d:t24refnolink/>110.3 for all occupancies. For nonresidential occupancies, compliance is demonstrated with requirements in <d:t24refnolink/>120.9. For multifamily residential and hotel/motel occupancies, compliance is also demonstrated with requirements in <d:t24refnolink/>160.4(d) / <d:t24refnolink/>170.2(d).</d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="H_WaterHeatingSystemName" type="hvac:WaterHeatingSystemName">
              <xsd:annotation>
                <xsd:documentation source="FieldText">System Name</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">
Result = F03_WaterHeatingSystemName
End If</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="H01_TempControlsCertification" type="comp:TempControlsCertification">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements">Construction documents require manufacturer certification that service water-heating systems are equipped with automatic temperature controls capable of adjusting temperature settings per <d:t24refnolink/>110.3(a).</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">If any row in section B has B02New_WaterHeatingSystem Or  B02Altered_WaterHeatingSystem == CentralNonresSpaces Or IndividualNonresSpaces user selects from radio buttons Yes result = ReqYes, Not Applicable result = ReqNA</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="H02_OutletTempControls" type="comp:OutletTempControls">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements">Systems with capacity <d:gt/> 167,000 BTUH equipped with outlet temperature controls per <d:t24refnolink/>110.3(c)1 unless covered by California Plumbing Code 613.0.</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">User selects from radio buttons Yes result = ReqYes, Not Applicable result = ReqNA
 
Mandatory Measure Triggers:
If result == ReqYes ;
MM110_3c1_MeasureApplies = true and is displayed
End If</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="H03_CirculatingPumpControls" type="comp:CirculatingPumpControls">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements">Controls for circulating pumps or electrical heat trace systems are capable of automatically turning off the system per <d:t24ref h="110.3(c)2"/> unless systems serves healthcare facility.</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">User selects from radio buttons Yes result = ReqYes, Not Applicable result = ReqNA
 
Mandatory Measure Triggers:
If result == ReqYes ;
MM110_3c2_MeasureApplies = true and is displayed
End If</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="H04_MultipleUnitsPumpControls" type="comp:MultipleUnitsPumpControls">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements">For recirculation systems serving multiple dwelling units, design includes a mechanical or digital thermostatic master mixing valve on each distribution supply and return loop per <d:t24refnolink/>170.2(d) or <d:t24refnolink/>180.1(b)3 for additions.</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">If any row in section B has B02New_WaterHeatingSystem Or  B02Altered_WaterHeatingSystem == CentralDwellingUnits user selects from radio buttons Yes result = ReqYes, Not Applicable result = ReqNA</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="H05_SingleUnitOnOffControls" type="comp:SingleUnitOnOffControls">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements">For recirculation systems serving individual dwelling units, design includes manual on/off controls as specified in Reference Appendix RA4.4.9 per  <d:t24refnolink/>170.2(d).</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">If any row in section B has B02New_WaterHeatingSystem Or  B02Altered_WaterHeatingSystem == IndividualDwellingUnits user selects from radio buttons Yes result = ReqYes, Not Applicable result = ReqNA</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="H06_BoilerAirShutOffReq" type="comp:BoilerAirShutOffReq">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements">Combustion air positive shut-off shall be provided per <d:t24refnolink/>120.9(a) &amp;amp; <d:t24refnolink/>160.4(d) on all newly installed commercial boilers as follows: <d:l t="*"><d:list> Boilers with input capacity <d:gte/> 2.5 MMBtu/h, in which the boiler is designed to operate with a nonpositive vent static pressure </d:list><d:list>Boilers where one stack serves two or more boilers with a total combined input capacity per stack of 2.5 MMBtu/h.</d:list></d:l></xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">If A03_WholeBuildingOccupancy == HighRiseResidential user selects from radio buttons Yes result = ReqYes, Not Applicable result = ReqNA</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="H07_BoilerFanMotorReq" type="comp:BoilerFanMotorReq">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements">Boiler combustion air fans with motor <d:gte/> 10 hp shall meet one of the following for newly installed boilers per <d:t24refnolink/>120.9(b) &amp;amp; <d:t24refnolink/>160.4(d)2: <d:l t="*"><d:list>  The fan motor shall be driven by a variable speed drive OR </d:list><d:list> The fan motor shall include controls that limit the fan motor demand to <d:lte/>30% of the total design wattage at 50% of the design air volume.</d:list></d:l></xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">If A03_WholeBuildingOccupancy == HighRiseResidential user selects from radio buttons Yes result = ReqYes, Not Applicable result = ReqNA</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="H08_BoilerStackGasReq" type="comp:BoilerStackGasReq">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements">Newly installed boilers with an input capacity {d:gte/] 5MMBtu/h and a steady state full-load combustion efficiency <d:lt/> 90% shall maintain excess (stack-gas) oxygen concentrations <d:lte/>  5% by volume on a dry basis over firing rates of 20-100%. Combustion air volume shall be controlled with respect to firing rate or flue gas oxygen concentration. Use of a common gas and combustion air control linkage or jack shaft is prohibited per <d:t24refnolink/>120.9(c) &amp;amp; <d:t24refnolink/>160.4(d)3.</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">If A03_WholeBuildingOccupancy == HighRiseResidential user selects from radio buttons Yes result = ReqYes, Not Applicable result = ReqNA</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="HErrorMessage_SectionErrorMessage" type="comp:SectionErrorMessage" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
              </xsd:annotation>
            </xsd:element>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="Section_I" minOccurs="1" maxOccurs="1">
        <xsd:annotation>
          <xsd:documentation source="FieldText">
            <d:b> I. ELECTRIC READY BUILDINGS </d:b>
          </xsd:documentation>
          <xsd:documentation source="MinOccurs">This section is required if A03_WholeBuildingOccupancy == HighRiseResidential</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="I_BeginNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i>This table includes electric ready requirements that must be met when installing gas or propane water heaters in dwelling units to demonstrate compliance with <d:t24refnolink/>160.9. </d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="I01_ElectricReadyScope" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">Systems serving multifamily occupancy that use gas or propane include:</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="I01a_ElectricReadyScope" type="comp:ElectricReadyScope">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Gas/propane water heater serving individual dwelling units</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements"/>
                <xsd:documentation source="CalculationsAndRules">If any row in section B has F02_WaterHeaterSpaceType == IndividualDwelling And F08_WaterHeaterType == InstantaneousConsumer or StorageResDutyCommercial result = ReqYes, else result = ReqNA</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="I01b_ElectricReadyScope" type="comp:ElectricReadyScope">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Gas/propane water heater serving multiple dwelling units</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements"/>
                <xsd:documentation source="CalculationsAndRules">If any row in section B has F02_WaterHeaterSpaceType == MultipleDwelling And F08_WaterHeaterType == InstantaneousConsumer or StorageResDutyCommercial result = ReqYes, else result = ReqNA</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="I01c_ElectricReadyScope" type="comp:ElectricReadyScope">
              <xsd:annotation>
                <xsd:documentation source="FieldText">None of these</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements"/>
                <xsd:documentation source="CalculationsAndRules">If any row in section B has F02_WaterHeaterSpaceType != IndividualDwelling or MultipleDwelling Or F08_WaterHeaterType != InstantaneousConsumer or StorageResDutyCommercial result = ReqYes, else result = ReqNA</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="TableI_Individual">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Gas/Propane Water Heaters Serving Individual Dwelling Units - <d:t24refnolink/>160.9(e)</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules"> Triggered if I01a_ElectricReadyScope = ReqYes </xsd:documentation>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="Individual" type="hvac:WaterHeatingSystemName">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">System Name</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">
Result = F03_WaterHeatingSystemName
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="I02_ElectricReadyRequirement" type="comp:ElectricReadyRequirement">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements"><d:t24refnolink/>160.9(e)2: A condensate drain that is no more than 2 inches higher than the base of the installed water heater, and allows natural draining without pump assistance.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules"> User checks Yes result = ReqYes Or No  result = ReqNo </xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="I03_ElectricReadyRequirement" type="comp:ElectricReadyRequirement">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">A ventilation method meeting the following per <d:t24refnolink/>160.9(e)4:
Dropdown options (only the one that is selected shows up): 
<d:l t="*"><d:list>The designated space for the future heat pump water heater shall have a minimum volume of 700 cubic feet; or
</d:list><d:list>The designated space for the future heat pump water heater shall vent to a communicating space in the same pressure boundary via permanent openings with a minimum total NFA of 250 square inches., so that the total combined volume connected via permanent openings is 700 cubic feet or larger. The permanent openings shall be:
   </d:list><d:list> Fully louvered doors with fixed louvers; or
   </d:list><d:list> Two permanent fixed openings located within 12 inches from the enclosure top and bottom;
</d:list><d:list> The designated space for the future heat pump water heater shall include two 8 inches capped ducts, venting to the building exterior:
   </d:list><d:list> All ducts, connections, and building penetrations shall be sealed.
   </d:list><d:list> Exhaust air ducts and all ducts which cross pressure boundaries shall be insulated to a minimum insulation level of R-6.
   </d:list><d:list> Airflow from termination points shall be diverted away from each other.</d:list></d:l></xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules"> User checks Yes result = ReqYes Or No  result = ReqNo </xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
            <xsd:element name="TableI_Multiple">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Gas/Propane Water Heaters Serving Multiple Dwelling Units - <d:t24refnolink/>160.9(f)</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules"> Triggered if I01b_ElectricReadyScope = ReqYes </xsd:documentation>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="MultipleDwelings" type="hvac:WaterHeatingSystemName">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">System Name</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">
Result = F03_WaterHeatingSystemName
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="I04_ElectricReadyRequirement" type="comp:ElectricReadyRequirement">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements"><d:t24refnolink/>160.9(f)2: Space shall be reserved for a Heat Pump. The minimum space reserved shall include space for service clearances and air flow clearances and shall meet the following:
Dropdown options (only the one that is selected shows up): 
<d:l t="*"><d:list>The space reserved shall be the space required for a heat pump water heater system that meets the total building hot water demand as calculated and documented by the responsible person associated with the project; or 
</d:list><d:list>The space reserved shall meet the requirements specified in Joint Appendix JA15.2.1.</d:list></d:l></xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules"> User checks Yes result = ReqYes Or No  result = ReqNo </xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="I05_ElectricReadyRequirement" type="comp:ElectricReadyRequirement">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements"><d:t24refnolink/>160.9(f)2B: Space shall be reserved for Tanks.The minimum space reserved shall include space for service clearances and shall meet the following:
Dropdown options (only the one that is selected shows up): 
<d:l t="*"><d:list>The space reserved shall be the space required for a heat pump water heater system that meets the total building hot water demand as calculated and documented by the responsible person associated with the project; or 
</d:list><d:list>The space reserved shall meet the requirements specified in Joint Appendix JA15.2.2.</d:list></d:l></xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules"> User checks Yes result = ReqYes Or No  result = ReqNo </xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="I06_ElectricReadyRequirement" type="comp:ElectricReadyRequirement">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements"><d:t24refnolink/>160.9(f)3: Ventilation shall be provided by meeting the following: 
Dropdown options (only the one that is selected shows up): 
<d:l t="*"><d:list>Physical space reserved for the heat pump shall be located outside; or
</d:list><d:list>A pathway shall be reserved for future routing of supply and exhaust air via ductwork from the reserved heat pump location to a suitable outdoor location. Penetrations through the building envelope for louvers and ducts shall be planned and identified for future use. The reserved pathway and penetrations through the building envelope shall be sized to meet one of the following:
   </d:list><d:list>The reserved pathway and penetrations shall be sized to serve a heat pump water heater system that meets the total building hot water demand as calculated and documented by the responsible person associated with the project.
   </d:list><d:list>The reserved pathway and penetrations shall be sized to meet the requirements specified in Joint Appendix JA15.2.3.</d:list></d:l></xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules"> User checks Yes result = ReqYes Or No  result = ReqNo </xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="I07_ElectricReadyRequirement" type="comp:ElectricReadyRequirement">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements"><d:t24refnolink/>160.9(f)4: Condensate drainage piping. An approved receptacle that is sized per the California Plumbing Code for condensate drainage shall be installed within 3 feet of the reserved heat pump location, or piping shall be installed from within 3 feet of the reserved heat pump location to an approved discharge location that is sized in accordance with the California Plumbing Code, and meet the following:
Dropdown options (only the one that is selected shows up): 
<d:l t="*"><d:list>Condensate drainage shall be sized to serve a heat pump water heater system that meets the total building hot water demand as calculated and documented by the responsible person associated with the project.
</d:list><d:list>Condensate drainage piping shall be sized to meet the requirements specified in Joint Appendix JA15.2.4.</d:list></d:l></xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules"> User checks Yes result = ReqYes Or No  result = ReqNo </xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="Section_J" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation source="FieldText">
            <d:b>J. Pool &amp;amp; SPAs</d:b>
          </xsd:documentation>
          <xsd:documentation source="CalculationsAndRules">If  B02New_WaterHeatingSystem or B02Altered_WaterHeatingSystem == PoolSpa
this section is required
End If</xsd:documentation>
          <xsd:documentation source="MinOccurs">If this section doesn't apply, do not display anything for this section</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="Pool_BeginNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i> This table documents compliance with mandatory pool/spa requirements in <d:t24refnolink/>110.4 / <d:t24refnolink/>160.7 </d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="Pool_PoolSpaHeated" type="comp:PoolSpaHeated">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Is the pool/Spa heated?</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="PoolSpa">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="Row" minOccurs="1" maxOccurs="unbounded">
                    <xsd:complexType>
                      <xsd:sequence>
                        <xsd:element name="Pool01_SystemDescription" type="comp:SystemDescription">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Pool/Spa Description</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="Pool02_PoolSpaService" type="comp:PoolSpaService">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Pool/Spa Service Type</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User selects from list: 
            MultipleUsers display term Serves multiple tenants or public
            SingleTenant display term Serves one tenant</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="Pool03_PoolSpaRequirements">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Efficiency</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User selects from list:  EfficiencyStandards display term Equipment subject to State/federal appliance efficiency standards is in the CEC's directory of certified equipment</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:PoolSpaRequirements">
                              <xsd:enumeration value="EfficiencyStandards"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name="Pool04_PoolSpaRequirements">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">On/Off Control</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User selects from list: OnOffSwitchProvided display term Includes on-off switch mounted on outside of heater allowing shutting off heater without adjusting thermostat</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:PoolSpaRequirements">
                              <xsd:enumeration value="NotHeatedNA"/>
                              <xsd:enumeration value="OnOffSwitchProvided"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name="Pool05_PoolSpaRequirements">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Instructions</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User selects from list: CoverProvided display term Heated outdoor pools/spas must include cover and weatherproof instruction for proper care of when cover is used
            NotHeatedNA display term NA: Pool/spa not heated</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:PoolSpaRequirements">
                              <xsd:enumeration value="Instructions"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name="Pool06_PoolSpaRequirements">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Covers</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User selects from list: CoverProvided display term Heated outdoor pools/spas must include cover and weatherproof instruction for proper care of when cover is used
            NotHeatedNA display term NA: Pool/spa not heated</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:PoolSpaRequirements">
                              <xsd:enumeration value="CoverProvided"/>
                              <xsd:enumeration value="CoverNA"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name="Pool07_PoolSpaRequirements">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Heating Equipment</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User selects from list:  NoElectResistanceHeat display term No electrical resistance heating used
            FullyInsulated display term Listed package units with fully insulated enclosures, and with tight-fitting covers that are insulated to at least R-6
            SolarRecoveredEnergy display term Pools/spas where greater or equal to 60% of annual heating energy is from site solar energy or recovered energy</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:PoolSpaRequirements">
                              <xsd:enumeration value="NoElectResistanceHeat"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name="Pool08_PoolSpaRequirements">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Heating Source Sizing</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">
User selects from list
If result == 1104Exempt5
   D03_ExceptionalConditionMessageCCPLBE += SARA
End If
</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:PoolSpaRequirements">
                              <xsd:enumeration value="SurfaceArea"/>
                              <xsd:enumeration value="Sizing"/>
                              <xsd:enumeration value="Renewables"/>
                              <xsd:enumeration value="SupplementaryHeater"/>
                              <xsd:enumeration value="Director"/>
                              <xsd:enumeration value="1104Exempt1"/>
                              <xsd:enumeration value="1104Exempt2"/>
                              <xsd:enumeration value="1104Exempt3"/>
                              <xsd:enumeration value="1104Exempt4"/>
                              <xsd:enumeration value="1104Exempt5"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name="Pool09_PoolSpaRequirements">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Piping</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User selects from list:  FutureSolarPiping display term greater than or equal to 36 in of pipe installed between filter and heater or dedicated suction and return lines to allow for the future addition of solar heating equipment
            FutureSolarConnections display term Built-in/built-up connections installed to allow for the future addition of solar heating equipment</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:PoolSpaRequirements">
                              <xsd:enumeration value="CoverNA"/>
                              <xsd:enumeration value="FutureSolarPiping"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name="Pool10_PoolSpaRequirements">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Pool Directional Inlets &amp;amp; Pump Control</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User selects from list: PoolInletsPump display term Has directional inlets to mix the pool water &amp;amp; control mechanism to allow pumps to run only during off-peak electric demand period and for min time necessary
            SpaNA display term NA: Spa</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:PoolSpaRequirements">
                              <xsd:enumeration value="PoolInletsPump"/>
                              <xsd:enumeration value="SpaNA"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                      </xsd:sequence>
                    </xsd:complexType>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
            <xsd:element name="PoolSingleTenant" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">
                  <d:b>Additional Requirements for Pool/Spa Serving One Tenant <d:t24refnolink/>150.0(p) </d:b>
                </xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">This subsection is required 
If Pool02_PoolSpaService == SingleTenant 
Else no data is collected and this subsection is not displayed</xsd:documentation>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="PoolSingle_SystemDescription" type="comp:SystemDescription">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Pool/Spa Description</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">Result = Pool01_SystemDescription</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="Pool11_PoolSpaOneTenantReqs">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">Dedicated-purpose pool pumps and replacement dedicated-purpose pump motors subject to State or Federal appliance standards shall be listed in the Commission's directory of certified equipment.
<d:l t="*"><d:list>Dedicated-purpose pool pumps shall meet 20 CCR § 1605.1(g)(7) of the Appliance Efficiency Regulations. 
</d:list><d:list>Replacement dedicated-purpose pool pumpmotors shall meet 20 CCR § 1605.3 of the Appliance Efficiency Regulations.</d:list></d:l></xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">User input.  If user checks the Yes box
result = PumpFlowRate
Else If box is unchecked
result = PoolReqNotMet and this section does not comply
End If</xsd:documentation>
                    </xsd:annotation>
                    <xsd:simpleType>
                      <xsd:restriction base="comp:PoolSpaOneTenantReqs">
                        <xsd:enumeration value="PoolReqNotMet"/>
                        <xsd:enumeration value="PumpFlowRate"/>
                      </xsd:restriction>
                    </xsd:simpleType>
                  </xsd:element>
                  <xsd:element name="Pool12_PoolSpaOneTenantReqs">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">All pump flow rates shall be calculated using H = C x F<d:sup>2</d:sup>
WHERE:
H is the total system head in feet of water
F is the flow rate in gallons per minute (gpm)
C is a coefficient based on the volume of the pool (0.0167 for pools less than or equal to 17,000 gallons and 0.0082 for pools greater than 17,000 gallons)</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">User input.  If user checks the Yes box
result = PumpFlowRate
Else If box is unchecked
result = PoolReqNotMet and this section does not comply
End If</xsd:documentation>
                    </xsd:annotation>
                    <xsd:simpleType>
                      <xsd:restriction base="comp:PoolSpaOneTenantReqs">
                        <xsd:enumeration value="PoolReqNotMet"/>
                        <xsd:enumeration value="PumpFlowRate"/>
                      </xsd:restriction>
                    </xsd:simpleType>
                  </xsd:element>
                  <xsd:element name="Pool13_PoolSpaOneTenantReqs">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">Filtration pumps shall be sized, or if programmable, shall be programmed, so that the filtration flow rate is not greater than the rate needed to turn over the pool water volume in 6 hours or 36 gpm, whichever is greater.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">User input.  If user checks the Yes box
result = FiltrationPumpSize
Else If box is unchecked
result = PoolReqNotMet and this section does not comply
End If</xsd:documentation>
                    </xsd:annotation>
                    <xsd:simpleType>
                      <xsd:restriction base="comp:PoolSpaOneTenantReqs">
                        <xsd:enumeration value="FiltrationPumpSize"/>
                        <xsd:enumeration value="PoolReqNotMet"/>
                      </xsd:restriction>
                    </xsd:simpleType>
                  </xsd:element>
                  <xsd:element name="Pool14_PoolSpaOneTenantReqs">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">Dedicated-purpose pool pumps with more than one speed shall have: 
<d:l t="*"><d:list>Multispeed pumps shall have controls which default to the filtration flow rate when no auxiliary pool loads are operating; and 
</d:list><d:list>Controls shall default to the filtration flow rate setting within 24 hours and shall have an override capability for servicing.</d:list></d:l></xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">If Pool02_PoolSpaService == Public, then User input.  
If user checks the Yes box
result = AuxPoolLoad 
Else If user checks the Not Applicable box
result = PoolReqNA
Else If both Yes box and Not Applicable box are unchecked
result = PoolReqNotMet and this section does not comply
End If</xsd:documentation>
                    </xsd:annotation>
                    <xsd:simpleType>
                      <xsd:restriction base="comp:PoolSpaOneTenantReqs">
                        <xsd:enumeration value="AuxPoolLoad"/>
                        <xsd:enumeration value="PoolReqNA"/>
                        <xsd:enumeration value="PoolReqNotMet"/>
                      </xsd:restriction>
                    </xsd:simpleType>
                  </xsd:element>
                  <xsd:element name="Pool15_PoolSpaOneTenantReqs">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">System Piping must meet the following requirements: 
- A length of straight pipe that is greater than or equal to at least 4 pipe diameters shall be installed before the pump; and
- Pool piping shall be sized so that the velocity of the water at maximum flow for auxiliary pool loads does not exceed 8 feet per second in the return line and 6 feet per second in the suction line; and 
- All elbows shall be sweep elbows or of an elbow-type that has a pressure drop of less than the pressure drop of straight pipe with a length of 30 pipe diameters.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">If Pool02_PoolSpaService == Public, then User input.  If user checks the Yes box
result = PoolPiping
Else If box is unchecked
result = PoolReqNotMet and this section does not comply
End If</xsd:documentation>
                    </xsd:annotation>
                    <xsd:simpleType>
                      <xsd:restriction base="comp:PoolSpaOneTenantReqs">
                        <xsd:enumeration value="PoolPiping"/>
                        <xsd:enumeration value="PoolReqNotMet"/>
                      </xsd:restriction>
                    </xsd:simpleType>
                  </xsd:element>
                  <xsd:element name="Pool16_PoolSpaOneTenantReqs">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">Filters shall be at least the size specified in NSF/ANSI 50 for public pool intended applications.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">If Pool02_PoolSpaService == Public, then User input.  If user checks the Yes box
result = FilterSize
Else If box is unchecked
result = PoolReqNotMet and this section does not comply
End If</xsd:documentation>
                    </xsd:annotation>
                    <xsd:simpleType>
                      <xsd:restriction base="comp:PoolSpaOneTenantReqs">
                        <xsd:enumeration value="FilterSize"/>
                        <xsd:enumeration value="PoolReqNotMet"/>
                      </xsd:restriction>
                    </xsd:simpleType>
                  </xsd:element>
                  <xsd:element name="Pool17_PoolSpaOneTenantReqs">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">Minimum diameter of backwash valves shall be 2 inches or the diameter of the return pipe, whichever is greater.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">User input.  If user checks the Yes box
result = BackwashValves
Else If box is unchecked
result = PoolReqNotMet and this section does not comply
End If</xsd:documentation>
                    </xsd:annotation>
                    <xsd:simpleType>
                      <xsd:restriction base="comp:PoolSpaOneTenantReqs">
                        <xsd:enumeration value="BackwashValves"/>
                        <xsd:enumeration value="PoolReqNotMet"/>
                      </xsd:restriction>
                    </xsd:simpleType>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="Section_Lmci" minOccurs="1">
        <xsd:annotation>
          <xsd:documentation source="FieldText">K. DECLARATION OF REQUIRED CERTIFICATES OF INSTALLATION</xsd:documentation>
          <xsd:documentation source="MinOccurs">This section is required.</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>

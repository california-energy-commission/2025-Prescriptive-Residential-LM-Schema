Mandatory Measure Triggers:  
Multi-field triggers: See G01_AirReleaseValve CalculationsAndRules for trigger values from this field</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G05_TankDrainPort" type="comp:TankDrainPort">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                      <xsd:documentation source="AdditionalRequirements">Cold water and recirculation loop piping shall not be connected to the hot water storage tank drain port per <d:t24refnolink/>110.3(c)4E</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">User select from radio buttons Yes result = ReqYes, No result = ReqNo
 
Mandatory Measure Triggers:  
Multi-field triggers: See G01_AirReleaseValve CalculationsAndRules for trigger values from this field</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G06_ColdWaterCheckValve" type="comp:ColdWaterCheckValve">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                      <xsd:documentation source="AdditionalRequirements">Check valve installed on cold water supply between hot water system and next closest tee on cold water supply per <d:t24refnolink/>110.3(c)4F</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">User select from radio buttons Yes result = ReqYes, No result = ReqNo
 
Mandatory Measure Triggers:  
Multi-field triggers: See G01_AirReleaseValve CalculationsAndRules for trigger values from this field</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G08_RecircLoopHP" type="comp:RecircLoopHP">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                      <xsd:documentation source="AdditionalRequirements">DWELLING UNITS ONLY: For heat pump water heating systems, the hot water return from the recirculation loop shall connect to a recirculation loop tank and shall not directly connect to the primary heat pump water heater inlet or the primary thermal storage tanks per <d:t24refnolink/>170.2(d)2Aii.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">If F23HP_EquipmentTypeApplies == true 
User selects from radio buttons Yes result = ReqYes and No result = ReqNo; 
Else result = ReqNA and row is grayed out
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G09_RecircFuelHP" type="comp:RecircFuelHP">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                      <xsd:documentation source="AdditionalRequirements">DWELLING UNITS ONLY: For heat pump water heating systems, the fuel source for the recirculation loop tank shall be electricity per <d:t24refnolink/>170.2(d)2Aiii.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">If F23HP_EquipmentTypeApplies == true 
User selects from radio buttons Yes result = ReqYes and No result = ReqNo; 
Else result = ReqNA and row is grayed out
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G09_RecircTemp" type="comp:RecircTemp">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                      <xsd:documentation source="AdditionalRequirements">DWELLING UNITS ONLY: The recirculation loop tank temperature setpoint shall be at least 10°F lower than the primary thermal storage tank temperature setpoint - <d:t24refnolink/>170.2(d)2Av</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">
User selects from radio buttons Yes result = ReqYes and No result = ReqNo; 
Else result = ReqNA and row is grayed out
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G10_PipingSize" type="comp:PipingSize">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                      <xsd:documentation source="AdditionalRequirements">DWELLING UNITS ONLY: All hot water distribution piping shall be sized in accordance with the California Plumbing Code Appendix M per <d:t24refnolink/>170.2(d)2C.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">
User selects from radio buttons Yes result = ReqYes and No result = ReqNo; 
Else result = ReqNA and row is grayed out
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G11_RecircThermostat" type="comp:RecircThermostat">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                      <xsd:documentation source="AdditionalRequirements">DWELLING UNITS ONLY:A recirculation system with mechanical or digital thermostatic master mixing valve on each distribution supply and return loop and meet the requirements in Reference Appendix RA4.4, unless building has ≤ 8 dwelling units, per <d:t24refnolink/>170.2(d)2D.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">
User selects from radio buttons Yes result = ReqYes and No result = ReqNo; 
Else result = ReqNA and row is grayed out
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G12_PipingInsulation" type="comp:PipingInsulation">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Requirement</xsd:documentation>
                      <xsd:documentation source="AdditionalRequirements">DWELLING UNITS ONLY: Insulation for hot water pipes shall be field verified as specifid in Reference Appendix RA3.6.3 per <d:t24refnolink/>170.2(d)2E.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">
User selects from radio buttons Yes result = ReqYes and No result = ReqNo; 
Else result = ReqNA and row is grayed out
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
            <xsd:element name="DistributionIndivUnits" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">
                  <d:b>Distribution of Individual System(s) Serving Dwelling Units - <d:t24refnolink/>170.2(d)1 </d:b>
                </xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">This subsection is required If B02New_WaterHeatingSystem == IndividualDwellingUnits Or B02Altered_WaterHeatingSystem == IndividualDwellingUnits</xsd:documentation>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="DistributionIndivUnits_WaterHeatingSystemName" type="hvac:WaterHeatingSystemName">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">System Name</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">
Result = F03_WaterHeatingSystemName
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G10_HeatPumpDistRequirement" type="comp:HeatPumpDistRequirement">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">Per <d:t24refnolink/>170.2(d)1A, single 240 volt heat pump water heaters serving dwelling units must also include systems with: <d:l t="*"><d:list> Compact hot water distribution system as specified in Reference Appendix RA4.4.16 in climate zones 1 and 16; AND </d:list><d:list> A drain water heat recovery system that is field verified by a HERS rater per Reference Appendix RA3.6.9 in climate zone 16</d:list></d:l></xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">If  F16_DwellingUnitWaterHeater includes HeatPumpWaterHeater240V   user input.  
Else 
result = ReqNA and row is grayed out
End If
 
If  Yes radio button is selected then 
If only first subrow checkbox is checked 
result = ReqHeatPumpCompact 
Else if only second subrow checkbox is checked result = ReqHeatPumpDWHR; 
Else If  first subrow  and second subrow checkboxes are checked 
result = ReqHeatPumpCompactDWHR
Else If neither first nor second subrows are checked
result = ReqHeatPumpYes
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G11_IndividualSysDistRequirement" type="comp:IndividualSysDistRequirement">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">A drain water heat recovery system that is field verified by a HERS rater per Reference Appendix RA3.6.9 in climate zone 16 per <d:t24refnolink/>170.2(d)1B.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">If B01b_PlumbingProjectScope != NewSystem Or F16_DwellingUnitWaterHeater does not include  HeatPumpNEEA
 result = ReqDWHRCZ16NA and row is grayed out; 
Else  User input. and Not Applicable radio button is grayed out
End If
If user selects the Yes radio button result = ReqDWHRCZ16 
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="G15_IndividualSysDistRequirement" type="comp:IndividualSysDistRequirement">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText"/>
                      <xsd:documentation source="AdditionalRequirements">For recirculation distribution systems serving individual dwelling units, only Demand Recirculation Systems with manual on/off control as specified in the Reference Appendix RA4.4.9 shall be used per <d:t24refnolink/>170.2(d)1.</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">This row is always displayed and required if this subsection is triggered
User input
If user seleects Yes radio buton
result = ReqDemandRecirc
Else If user selects Not Appicable radio button
result = ReqDemandRecircNA
End If</xsd:documentation>
                    </xsd:annotation>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
            <xsd:element name="G13ToG15Heading" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:b>Mandatory Pipe Insulation All Occupancies - <d:t24refnolink/>120.3, <d:t24refnolink/>160.4 </d:b>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="G16ToG18_WaterHeatingSystemName" type="hvac:WaterHeatingSystemName">
              <xsd:annotation>
                <xsd:documentation source="FieldText">System Name</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">
Result = F03_WaterHeatingSystemName
End If</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:choice maxOccurs="1">
              <xsd:element name="G13_DwellingUnitsPipeInsulationComplies" type="comp:DwellingUnitsPipeInsulationComplies">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="AdditionalRequirements">For systems serving dwelling units, pipe insulation must meet the minimum insulation requirements in Table 160.4-A (see blow) except:<d:l t="*"><d:list>  Piping that penetrates framing members shall not be required to have pipe insulation for the distance of the framing penetration. Piping that penetrates metal framing shall use grommets, plugs, wrapping or other insulating material to assure that no contact is made with the metal framing. Insulation shall abut securely against all framing members </d:list><d:list>  Piping installed in interior or exterior walls shall not be required to have pipe insulation if all of the requirements are met for compliance with Quality Insulation Installation (QII) as specified in the Reference Residential Appendix RA3.5. </d:list><d:list> Piping surrounded with a minimum of 1 inch of wall insulation, 2 inches of crawlspace insulation, or 4 inches of attic insulation, shall not be required to have pipe insulation.</d:list></d:l></xsd:documentation>
                  <xsd:documentation source="CalculationsAndRules">If any row in section B has B02New_WaterHeatingSystem Or  B02Altered_WaterHeatingSystem == CentralDwellingUnits Or IndividualDwellingUnits  user input;  If checked result = true; else result = false.</xsd:documentation>
                </xsd:annotation>
              </xsd:element>
              <xsd:element name="G13_NotApplicableMessage">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="CalculationsAndRules">If NO  row in section B has B02New_WaterHeatingSystem Or  B02Altered_WaterHeatingSystem == CentralDwellingUnits Or IndividualDwellingUnits 
result = BlankGrayedOut stored in NotApplicableMessage
End If</xsd:documentation>
                </xsd:annotation>
                <xsd:simpleType>
                  <xsd:restriction base="comp:NotApplicableMessage">
                    <xsd:enumeration value="BlankGrayedOut"/>
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
            </xsd:choice>
            <xsd:choice maxOccurs="1">
              <xsd:element name="G14_NonresPipeInsulationComplies" type="comp:NonresPipeInsulationComplies">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="AdditionalRequirements">For systems serving nonresidential spaces, pipe insulation for the following applications is specified to comply with Table 120.3-A1 or Table 120.3-A2 (see below) per <d:t24refnolink/>120.3: <d:l t="*"><d:list> Recirculating system piping, including supply and return piping of the water heater </d:list><d:list> The first 8 ft of hot and cold outlet piping, including between storage tank and heat trap, for a nonrecirculating storage system </d:list><d:list> Pipes that are externally heated </d:list></d:l></xsd:documentation>
                  <xsd:documentation source="CalculationsAndRules">If any row in section B has B02New_WaterHeatingSystem Or  B02Altered_WaterHeatingSystem == CentralNonresSpaces Or IndividualNonresSpaces 
user input: 
End If
 
If checked result = true; 
else result = false.
End If
 
Mandatory Measure Triggers:
If result == true And G15_PipeInsulationProtectionComplies == true
MM120_3_MeasureApplies  = true and is displayed 
End If</xsd:documentation>
                </xsd:annotation>
              </xsd:element>
              <xsd:element name="G14_NotApplicableMessage">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="CalculationsAndRules">If no row in section B has B02New_WaterHeatingSystem Or  B02Altered_WaterHeatingSystem == CentralNonresSpaces Or IndividualNonresSpaces 
result = BlankGrayedOut stored in NotApplicableMessage
End If</xsd:documentation>
                </xsd:annotation>
                <xsd:simpleType>
                  <xsd:restriction base="comp:NotApplicableMessage">
                    <xsd:enumeration value="BlankGrayedOut"/>
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
            </xsd:choice>
            <xsd:element name="G15_PipeInsulationProtectionComplies" type="comp:PipeInsulationProtectionComplies">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">Per <d:t24refnolink/>120.3(b)/ <d:t24refnolink/>160.4(f), pipe and appurtenance insulation shall be protected from damage, including that due to sunlight, moisture, equipment maintenance, and wind.  Insulation exposed to weather shall be installed with a cover suitable for outdoor service.  Pipe insulation buried below grade must be installed in a water proof and non-crushable casing or sleeve.</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">User input: If checked result = true; else result = false  End If
 
Mandatory Measure Triggers:  
Multi-field triggers:  See G14_NonresPipeInsulationComplies CalculationsAndRules for trigger values from this field</xsd:documentation>
              </xsd:annotation>
            </xsd:element>

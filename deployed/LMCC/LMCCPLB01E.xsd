              <xsd:element name="Footer" type="comp:Footer"/>
            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>
        <xsd:element name="Report" type="xsd:base64Binary"/>
        <xsd:element name="ReportMMB" type="xsd:base64Binary" minOccurs="0"/>
      </xsd:sequence>
      <xsd:attribute name="revision" use="required" type="xsd:string" fixed="rev 20250101"/>
      <xsd:attribute name="doc" use="required" type="comp:ComplianceDocumentTag" fixed="LMCCPLB01E"/>
    </xsd:complexType>
  </xsd:element>
  <xsd:complexType name="LMCCPLB01E">
    <xsd:annotation>
      <xsd:documentation>Domestic Water Heating System</xsd:documentation>
    </xsd:annotation>
    <xsd:sequence>
      <xsd:element name="Section_A" minOccurs="1" maxOccurs="1">
        <xsd:annotation>
          <xsd:documentation source="FieldText">GENERAL INFORMATION</xsd:documentation>
          <xsd:documentation source="MinOccurs">This section is required.</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="A_BeginNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i>This document is used to demonstrate compliance with requirements in <d:t24refnolink/>110.1, <d:t24refnolink/>110.3, <d:t24refnolink/>120.3, and <d:t24refnolink/>140.5, and with requirements in <d:t24refnolink/>141.0 for additions and alterations, for domestic water heating systems serving nonresidential occupancies within low-rise mixed use buildings  using the prescriptive path. For low-rise residential and hotel/motel occupancies compliance is demonstrated with requirements in <d:t24refnolink/>110.1, <d:t24refnolink/>110.3, <d:t24refnolink/>160.4 and <d:t24refnolink/>170.2(d), and with requirements <d:t24refnolink/>180.1 for additions and <d:t24refnolink/>180.2 for alterations.</d:i>
                </xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">This note should be placed after the header and before section A</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="A01_ProjectCity" type="comp:ProjectCity">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Project Location (city)</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="A02_ClimateZone" type="com:ClimateZone">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Climate Zone</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">User selects from list of 1-16 climate zone numbers</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="A03_WholeBuildingOccupancy" minOccurs="1" maxOccurs="unbounded">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Occupancy Types Within Project (select all that apply):</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">User selects one or more occupancy types in the project: and only those selected are displayed in the report.</xsd:documentation>
                <xsd:appinfo source="displayterm">
                  <dtyp:displayterm value="RestaurantBuilding">Restaurant/Commercial Kitchen</dtyp:displayterm>
                  <dtyp:displayterm value="LowRiseResidential">Low-rise multifamily <d:lte/> 3 stories</dtyp:displayterm>
                </xsd:appinfo>
              </xsd:annotation>
              <xsd:simpleType>
                <xsd:restriction base="com:WholeBuildingOccupancy">
                  <xsd:enumeration value="AllOthersBuildings"/>
                  <xsd:enumeration value="AuditoriumBuilding"/>
                  <xsd:enumeration value="ClassroomBuilding"/>
                  <xsd:enumeration value="CommercialIndustrialBuilding"/>
                  <xsd:enumeration value="ConventionCenterBuilding"/>
                  <xsd:enumeration value="DataCenterBuilding"/>
                  <xsd:enumeration value="FinancialInstitutionBuilding"/>
                  <xsd:enumeration value="GroceryStoreBuilding"/>
                  <xsd:enumeration value="GymnasiumBuilding"/>
                  <xsd:enumeration value="HospitalBuilding"/>
                  <xsd:enumeration value="HotelMotel"/>
                  <xsd:enumeration value="LibraryBuilding"/>
                  <xsd:enumeration value="LowRiseResidential"/>
                  <xsd:enumeration value="MedicalClinicBuilding"/>
                  <xsd:enumeration value="OfficeBuilding"/>
                  <xsd:enumeration value="ParkingGarageBuilding"/>
                  <xsd:enumeration value="ReligiousFacilityBuilding"/>
                  <xsd:enumeration value="RelocatablePublicSchoolBuilding"/>
                  <xsd:enumeration value="RestaurantBuilding"/>
                  <xsd:enumeration value="RetailBuilding"/>
                  <xsd:enumeration value="SchoolBuilding"/>
                  <xsd:enumeration value="SportsArenaBuilding"/>
                  <xsd:enumeration value="StateBuilding"/>
                  <xsd:enumeration value="SupportArea"/>
                  <xsd:enumeration value="TheaterBuilding"/>
                  <xsd:enumeration value="Warehouse"/>
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:element>
            <xsd:element name="A04a_ConditionedFloorArea" type="com:ConditionedFloorArea">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Conditioned Floor Area (ft<d:sup>2</d:sup>)</xsd:documentation>
                <xsd:documentation source="AdditionalRequirements"/>
                <xsd:documentation source="CalculationsAndRules">User input;</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="A04_RequestedMMB" type="comp:RequestedMMB" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">NOT REPORTED IN PDF</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">This is a flag set by the agent that generates the report XML data to indicate that the user requested a Mandatory Measures Note Block which is placed after the DeclarationBlock in the XML output.</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="A05_ProjectScopeNR">
              <xsd:annotation>
                <xsd:documentation source="FieldText">NOT REPORTED IN PDF</xsd:documentation>
                <xsd:appinfo source="displayterm">
                  <dtyp:displayterm value="AdditionComplete">Addition</dtyp:displayterm>
                  <dtyp:displayterm value="ExistingAdditionAndAlteration">Addition Alteration</dtyp:displayterm>
                  <dtyp:displayterm value="ExistingAlteration">Alteration</dtyp:displayterm>
                  <dtyp:displayterm value="NewComplete">New</dtyp:displayterm>
                </xsd:appinfo>
              </xsd:annotation>
              <xsd:simpleType>
                <xsd:restriction base="comp:ProjectScopeNR">
                  <xsd:enumeration value="AdditionComplete"/>
                  <xsd:enumeration value="ExistingAdditionAndAlteration"/>
                  <xsd:enumeration value="ExistingAlteration"/>
                  <xsd:enumeration value="NewComplete"/>
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:element>
            <xsd:element name="A06_TotalGrossFloorArea" type="com:TotalGrossFloorArea">
              <xsd:annotation>
                <xsd:documentation source="FieldText">NOT REPORTED IN PDF</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="A08_IsProjectAllElectric" type="comp:IsProjectAllElectric">
              <xsd:annotation>
                <xsd:documentation source="FieldText">NOT REPORTED IN PDF</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="A09_GasType" type="com:GasType">
              <xsd:annotation>
                <xsd:documentation source="FieldText">NOT REPORTED IN PDF</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">Values are NaturalGas, Propane and None</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="Section_B" minOccurs="1" maxOccurs="1">
        <xsd:annotation>
          <xsd:documentation source="FieldText">PROJECT SCOPE</xsd:documentation>
          <xsd:documentation source="MinOccurs">This section is required.</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="B_BeginNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i>This table includes domestic water heating systems that are within the scope of the permit application and are demonstrating compliance using the prescriptive paths outlined in <d:t24refnolink/>140.5/ <d:t24refnolink/>170.2(d) and  <d:t24refnolink/>141.0(a)/<d:t24refnolink/>180.1, or  <d:t24refnolink/>141.0(b)2N / <d:t24refnolink/>180.2 for additions or alterations.  Solar water heating systems are documented on the LMCC-SAB compliance document.  Combined hydronic water heating systems are documented on the LMCC-MCH compliance document.</d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="B01Label" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">My project consists of (check all that apply):</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="B03Label" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">System Components</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="TableNew">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="Row" minOccurs="1" maxOccurs="unbounded">
                    <xsd:complexType>
                      <xsd:sequence>
                        <xsd:element name="B01a_PlumbingProjectScope">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">New system (DHW system being installed for the first time)</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User input.  If user checks this box, result = NewSystem Else result = NotApplicableScope</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:PlumbingProjectScope">
                              <xsd:enumeration value="NewSystem"/>
                              <xsd:enumeration value="NotApplicableScope"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name="B02New_WaterHeatingSystem" type="hvac:WaterHeatingSystem" minOccurs="0">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">System Type <d:sup>1,2</d:sup></xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">In current row If B01a_PlumbingProjectScope == NewSystem, this field is required. 
 User selects from list: CentralNonresSpaces display term Central System (serving nonresidential spaces), IndividualNonresSpaces display term Individual System (serving nonresidential spaces), CentralDwellingUnits display term Central System (serving 2 or more dwelling units), IndividualDwellingUnits display term Individual Dwelling Units System(s),  SolarThermalSystem display term Dwelling Unit Solar Thermal System, CombinedHydronic display term Combined Hydronic System.</xsd:documentation>
                            <xsd:appinfo source="displayterm">
                              <dtyp:displayterm value="CentralDwellingUnits">Central System (serving 2 or more dwelling units) <d:sup>2, 3</d:sup></dtyp:displayterm>
                              <dtyp:displayterm value="IndividualDwellingUnits">Individual Dwelling Units System(s) <d:sup>2</d:sup></dtyp:displayterm>
                              <dtyp:displayterm value="IndividualNonresSpaces">Individual System (serving nonresidential spaces) <d:sup>1</d:sup></dtyp:displayterm>
                            </xsd:appinfo>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="B03aNew_ProjectHasEquipment" type="comp:ProjectHasEquipment" minOccurs="0">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Equipment</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">In current row If B01a_PlumbingProjectScope == NewSystem, this field is required. If B02_WaterHeatingSystem == SolarThermalSystem user input; Else result = true</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="B03bNew_ProjectHasDistribution" type="comp:ProjectHasDistribution" minOccurs="0">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Distribution</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">In current row If B01a_PlumbingProjectScope == NewSystem, this field is required. If B02_WaterHeatingSystem == SolarThermalSystem user input; Else result = true</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="B03cNew_ProjectHasControls" type="comp:ProjectHasControls" minOccurs="0">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Controls</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">In current row If B01a_PlumbingProjectScope == NewSystem, this field is required. If B02New_WaterHeatingSystem == SolarThermalSystem user input; Else result = true</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                      </xsd:sequence>
                    </xsd:complexType>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
            <xsd:element name="TableAltered">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="Row" minOccurs="1" maxOccurs="unbounded">
                    <xsd:complexType>
                      <xsd:sequence>
                        <xsd:element name="B01b_PlumbingProjectScope">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">System Alteration (equipment, distribution or controls)</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">User input.  if user checks this box, result = AlteredSystem Else result = NotApplicableScope</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:PlumbingProjectScope">
                              <xsd:enumeration value="AlteredSystem"/>
                              <xsd:enumeration value="NotApplicableScope"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name="B02Altered_WaterHeatingSystem" type="hvac:WaterHeatingSystem" minOccurs="0">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">System Type <d:sup>1,2</d:sup></xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">In the current row If B01b_PlumbingProjectScope == AlteredSystem, this field is required.  User selects from list: CentralNonresSpaces display term Central System (serving nonresidential spaces), IndividualNonresSpaces display term Individual System (serving nonresidential spaces), CentralDwellingUnits display term Central System (serving 2+dwelling units), IndividualDwellingUnits display term Individual Dwelling Units System(s),  SolarThermalSystem display term Solar Thermal System, CombinedHydronic display term Combined Hydronic System</xsd:documentation>
                            <xsd:appinfo source="displayterm">
                              <dtyp:displayterm value="CentralDwellingUnits">Central System (serving 2 or more dwelling units) <d:sup>2, 3</d:sup></dtyp:displayterm>
                              <dtyp:displayterm value="IndividualDwellingUnits">Individual Dwelling Units System(s) <d:sup>2</d:sup></dtyp:displayterm>
                              <dtyp:displayterm value="IndividualNonresSpaces">Individual System (serving nonresidential spaces) <d:sup>1</d:sup></dtyp:displayterm>
                            </xsd:appinfo>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="B03aAltered_ProjectHasEquipment" type="comp:ProjectHasEquipment" minOccurs="0">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Equipment</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">In the current row If B01b_PlumbingProjectScope == AlteredSystem, this field is required.  User input; If checked result = true; else result = false
 
Mandatory Measure Triggers:
If result == true
If F08_WaterHeaterType   == StorageConsumerStorageResDutyCommercial  Or  StorageConsumerElectric
MM110_8d2_MeasureApplies  = true and is displayed 
 
Else If F08_WaterHeaterType ==  StorageCommercial Or  StorageCommercialElectric
MM110_8d2_MeasureApplies  = true and is displayed 
End If
End If</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="B03bAltered_ProjectHasDistribution" type="comp:ProjectHasDistribution" minOccurs="0">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Distribution</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">In the current row If B01b_PlumbingProjectScope == AlteredSystem, this field is required.  User input; If checked result = true; else result = false</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="B03cAltered_ProjectHasControls" type="comp:ProjectHasControls" minOccurs="0">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Controls</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">In the current row If B01a_PluB01b_PlumbingProjectScopembingProjectScope == AlteredSystem, this field is required.  User input; If checked result = true; else result = false</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                      </xsd:sequence>
                    </xsd:complexType>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
            <xsd:element name="B_Alert1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">Gas or propane central water heating systems serving multiple dwelling units require a solar water heating system per <d:t24refnolink/>170.2(d)3.  Solar water heating systems are documented on the LMCC-SAB compliance document. If solar water heating systems are in conjunction with non-solar systems to meet the water heating needs of the building, document the non-solar systems on this compliance document.</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">If any row in section B has B02New_WaterHeatingSystem Or B02Altered_WaterHeatingSystem == CentralDwellingUnits Or  SolarThermalSystem 
D03_ExceptionalConditionMessageCCPLBE += UseLMCCSAB01E And display this alert
End If</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="B_Alert2" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:b>
                    <d:i>Note: If combined hydronic water heating systems are used in conjunction with domestic only systems to meet the water heating needs of the building, document the domestic only systems on this compliance document. </d:i>
                  </d:b>
                </xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">If any row in section B has B02New_WaterHeatingSystem Or B02Altered_WaterHeatingSystem == CombinedHydronic 
D03_ExceptionalConditionMessageCCPLBE += UseLMCCMCH01E And display this alert 
End If</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="BEndNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i><d:sup>1</d:sup>FOOTNOTES:  Point of use water heaters, or other non-central systems used to serve nonresidential spaces, are considered individual systems.  </d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="BEndNote2" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i><d:sup>2</d:sup> Dwelling units refers to hotel/motel guest rooms and units in a  multifamily residential occupancy. </d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="BEndNote3" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i><d:sup>3</d:sup> DHW systems serving 2 or more dwelling units are considered "Central Systems" for multifamily and hotel/motel occupancies </d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="Section_C" minOccurs="1">
        <xsd:annotation>
          <xsd:documentation source="FieldText">COMPLIANCE RESULTS</xsd:documentation>
          <xsd:documentation source="MinOccurs">This section is required.</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="C_BeginNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i>Table C will indicate if the project data input into the compliance document is compliant with water heating requirements. If this table says "DOES NOT COMPLY" or  "COMPLIES with Exceptional Conditions"  refer to Table D. or the table indicated as not compliant for guidance.</d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="C01ColumnLabel1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Domestic Hot Water Equipment</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="C01ColumnLabel2" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Table F</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:choice maxOccurs="1">
              <xsd:element name="C01_DoesWaterHeatingEquipmentComply" type="comp:DoesWaterHeatingEquipmentComply">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="CalculationsAndRules">If Section_F NotPresent 
result = BlankGrayedOut stored in NotApplicableMessage; 
  
Else 
If  In Section_F TableSystems IsPresent then in all rows where these fields are present
If   F05_IsEfficiencyCapWeightedAvg  == false Then 
If (F11_ThermalEfficiency GTE F12_ThermalEfficiencyMinimum 
Or F11_EfficiencyAFUE GTE F12_EfficiencyMinimumValueAFUE  
Or F11_UniformEnergyFactor GTE F12_MinimumRequiredUEF)
And  
(in rows where  F14_NotApplicableMessage And F15_NotApplicableMessage NotPresent, 
If F14_StandbyLoss LTE F15_StandbyLossMaxAllowed 
Or F14_WaterHeaterStandbyLossFraction LTE F15_StandbyLossMaxAllowedFraction )
result = true display term Yes; 
Else result = false display term No
End If
 
Else If F05_IsEfficiencyCapWeightedAvg == true And F06_EfficiencyCapWeightedAvg GTE 90%
 
If (F11_ThermalEfficiency GTE F12_ThermalEfficiencyMinimum 
Or F11_EfficiencyAFUE GTE F12_EfficiencyMinimumValueAFUE  
Or F11_UniformEnergyFactor GTE F12_MinimumRequiredUEF)
And 
(in rows where  F14_NotApplicableMessage And F15_NotApplicableMessage NotPresent, 
F14_StandbyLoss LTE F15_StandbyLossMaxAllowed 
Or F14_WaterHeaterStandbyLossFraction LTE F15_StandbyLossMaxAllowedFraction )
result = true display term Yes; 
Else result = false display term No
End If
End If 
 
Continue evaluation If result == true,
 
If DwellingUnitEquipment IsPresent then 
If F17_NewUnitGasWaterHeater == ReqYes or ReqNA; 
result = true display term Yes; 
Else result = false display term No
End If
Continue evaluation If result == true,
If F18_StorageTankInsulation  F19_StateBuildingWaterHeatingEnergy And F20_InstantaneousIsolationValves  and F21_SchoolHeatPumpWH == ReqYes or ReqNA Then 
result = true display term Yes; 
Else result = false display term No
End If
End If</xsd:documentation>
                </xsd:annotation>
              </xsd:element>
              <xsd:element name="C01_NotApplicableMessage">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="CalculationsAndRules">If in section B no row has B03aNew_ProjectHasEquipment == true 
Or B03aAltered_ProjectHasEquipment == true 
result = BlankGrayedOut stored in NotApplicableMessage
End If</xsd:documentation>
                </xsd:annotation>
                <xsd:simpleType>
                  <xsd:restriction base="comp:NotApplicableMessage">
                    <xsd:enumeration value="BlankGrayedOut"/>
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
            </xsd:choice>
            <xsd:element name="C02ColumnLabel1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Distribution Systems</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="C02ColumnLabel2" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Table G</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:choice maxOccurs="1">
              <xsd:element name="C02_DoesWaterHeatingDistributionComply" type="comp:DoesWaterHeatingDistributionComply">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="CalculationsAndRules">If Section_G IsPresent
If RecircLoops IsPresent then 
If G01_AirReleaseValve, G02_BackflowCheckValve,  G03_HoseBibb,  G04_IsolationValves,  G05_ TankDrainPort,  G06_ColdWaterCheckValve, G07_RecircLoopHP, And G08_RecircFuelHP   !=ReqNo; 
 
And G10_HeatPumpDistRequirement != ReqHeatPumpNo 
And G11_IndividualSysDistRequirement != ReqDWHRCZ16No  
And G15_IndividualSysDistRequirement  != ReqDemandRecircNo
And G16_DwellingUnitsPipeInsulationComplies != false
And G14_NonresPipeInsulationComplies != false 
And G15_PipeInsulationProtectionComplies != false then 
result = true; 
Else result = false
End If
End If
End If</xsd:documentation>
                </xsd:annotation>
              </xsd:element>
              <xsd:element name="C02_NotApplicableMessage">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="CalculationsAndRules">If Section_G NotPresent because in section B no row has B03bNew_ProjectHasDistribution == true Or B03bAltered_ProjectHasDistribution == true 
result = BlankGrayedOut stored in NotApplicableMessage
End If</xsd:documentation>
                </xsd:annotation>
                <xsd:simpleType>
                  <xsd:restriction base="comp:NotApplicableMessage">
                    <xsd:enumeration value="BlankGrayedOut"/>
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
            </xsd:choice>
            <xsd:element name="C03ColumnLabel1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Controls</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="C03ColumnLabel2" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Table H</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:choice maxOccurs="1">
              <xsd:element name="C03_DoWaterHeatingControlsComply" type="comp:DoWaterHeatingControlsComply">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="CalculationsAndRules">If Section_H IsPresent 
If H01_TempControlsCertification,  H02_OutletTempControls,  H03_CirculatingPumpControls, H04_MultipleUnitsPumpControls, H05_SingleUnitOnOffControls And H06_BoilerAirShutOffReq, H07_BoilerFanMotorReq And H08_BoilerStackGasReq  != ReqNo 
result = true display term Yes; 
Else result = false display term No.
End If
End If</xsd:documentation>
                </xsd:annotation>
              </xsd:element>
              <xsd:element name="C03_NotApplicableMessage">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="CalculationsAndRules">If Section_H NotPresent because in section B no row has B03cNew_ProjectHasControls == true Or B03cAltered_ProjectHasControls == true 
result = BlankGrayedOut stored in NotApplicableMessage
End If</xsd:documentation>
                </xsd:annotation>
                <xsd:simpleType>
                  <xsd:restriction base="comp:NotApplicableMessage">
                    <xsd:enumeration value="BlankGrayedOut"/>
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
            </xsd:choice>
            <xsd:element name="C04ColumnLabel1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Pool/Spa</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="C04ColumnLabel2" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Table J</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:choice maxOccurs="1">
              <xsd:element name="C04_DoesPoolSpaComply" type="comp:DoesPoolSpaComply">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="CalculationsAndRules">
If Section_J IsPresent
   If Pool01 - Pool10 are complete 
   And Pool11 - Pool16 are complete if triggered,
      result =  true
   Else
      result = false
Else
   result = BlankGrayedOut stored in C03_NotApplicableMessage                              
                           </xsd:documentation>
                </xsd:annotation>
              </xsd:element>
              <xsd:element name="C04_NotApplicableMessage">
                <xsd:annotation>
                  <xsd:documentation source="FieldText"/>
                  <xsd:documentation source="CalculationsAndRules">
If Section_J NotPresent
   result = BlankGrayedOut
                           </xsd:documentation>
                </xsd:annotation>
                <xsd:simpleType>
                  <xsd:restriction base="comp:NotApplicableMessage">
                    <xsd:enumeration value="BlankGrayedOut"/>
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
            </xsd:choice>
            <xsd:element name="C05_DHW_Compliance" type="comp:DHW_Compliance">
              <xsd:annotation>
                <xsd:documentation source="FieldText">
                  <d:b>Compliance Results</d:b>
                </xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">If C01_ DoesWaterHeatingEquipmentComply Or C02_DoesWaterHeatingDistributionComply Or C03_DoWaterHeatingControlsComply == false 
result = DoesNotComply display term DOES NOT COMPLY; 
 
Else If D03_ExceptionalConditionMessageCCPLBE NotPresent 
result = Complies display term COMPLIES; 
Else result = CompliesExceptionalConditions display term COMPLIES with Exceptional Conditions
End If</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="Section_D" minOccurs="1">
        <xsd:annotation>
          <xsd:documentation source="FieldText">EXCEPTIONAL CONDITIONS</xsd:documentation>
          <xsd:documentation source="MinOccurs">This section is required.</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="D_BeginNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i>This table is auto-filled with uneditable comments because of selections made or data entered in tables throughout the form.</d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="TableAllExceptionalConditions" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="CalculationsAndRules">This table is required if there are any exceptional conditions</xsd:documentation>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="Row" minOccurs="1" maxOccurs="unbounded">
                    <xsd:complexType>
                      <xsd:sequence>
                        <xsd:element name="D01_SectionTitle" type="comp:SectionTitle">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText"/>
                            <xsd:documentation source="CalculationsAndRules">Auto-filled with the section title string + Permit Applicant Notes.</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="D02_SectionExceptionalConditionNotes" type="comp:SectionExceptionalConditionNotes" maxOccurs="unbounded">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText"/>
                            <xsd:documentation source="CalculationsAndRules">This combines all exceptional condition notes for the section defined in D01_SectionTitle.</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                      </xsd:sequence>
                    </xsd:complexType>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
            <xsd:element name="D03_ExceptionalConditionMessageCCPLBE" type="comp:ExceptionalConditionMessageCCPLBE" minOccurs="0" maxOccurs="unbounded">
              <xsd:annotation>
                <xsd:documentation source="FieldText">Exceptional Messages</xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">Auto-filled with any system generated messages that explain exceptional conditions encountered in the completed compliance document</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="Section_E" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation source="FieldText">ADDITIONAL REMARKS</xsd:documentation>
          <xsd:documentation source="CalculationsAndRules">This section is required if there are  comments from the permit applicant to the Authority Having Jurisdiction</xsd:documentation>
          <xsd:documentation source="MinOccurs">If this section doesn't apply, do not display anything for this section</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="E_BeginNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i>This table includes remarks made by the permit applicant to the Authority Having Jurisdiction.</d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="E01_CommentsToPermitAuthority" type="comp:CommentsToPermitAuthority" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
              </xsd:annotation>
            </xsd:element>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="Section_F" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation source="FieldText">DOMESTIC HOT WATER EQUIPMENT</xsd:documentation>
          <xsd:documentation source="CalculationsAndRules">This section is required is in section B any row has B03aNew_ProjectHasEquipment == true Or B03aAltered_ProjectHasEquipment == true
 
Mandatory Measure Triggers:
If this section is required    
MM110_3a_MeasureApplies  = true and is displayed And 
MM110_3b_MeasureApplies  = true and is displayed
End If</xsd:documentation>
          <xsd:documentation source="MinOccurs">If this section doesn't apply, do not display anything for this section</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="F_BeginNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">
                  <d:i>This table is used to demonstrate compliance with mandatory equipment requirements in  <d:t24refnolink/>110.1 and <d:t24refnolink/>110.3.  Compliance with prescriptive requirements in <d:t24refnolink/>140.5(c) /  <d:t24refnolink/>170.2(d) must also be demonstrated and with <d:t24refnolink/>141.0 / <d:t24refnolink/>180.1/ <d:t24refnolink/>180.2 for addition and alteration scopes. </d:i>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <xsd:element name="TableSystems">
              <xsd:annotation>
                <xsd:documentation source="FieldText">
                  <d:b>Equipment Schedule: Water Heating Efficiency and Standby Loss</d:b>
                </xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">This table is always required if Section F is required</xsd:documentation>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="Row" minOccurs="1" maxOccurs="unbounded">
                    <xsd:complexType>
                      <xsd:sequence>
                        <xsd:element name="F03_WaterHeatingSystemName" type="hvac:WaterHeatingSystemName">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">System Name</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">If B02New_WaterHeatingSystem  IsPresent And  B02New_WaterHeatingSystem ==  CentralNonresSpaces Or == CentralDwellingUnits 
Or If  B02Altered_WaterHeatingSystem  IsPresent And  B02Altered_WaterHeatingSystem ==  CentralNonresSpaces Or  == CentralDwellingUnits
 
User input
End If</xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="F02_WaterHeaterSpaceType" type="hvac:WaterHeaterSpaceType">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">Space type</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">
                                                User selects from list
                                             </xsd:documentation>
                          </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="F06_NotApplicableMessage ">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText">System Name</xsd:documentation>
                            <xsd:documentation source="CalculationsAndRules">If B02New_WaterHeatingSystem  IsPresent And  B02New_WaterHeatingSystem !=  CentralNonresSpaces And  != CentralDwellingUnits 
result = BlankGrayedOut
Else If B02Altered_WaterHeatingSystem  IsPresent And  B02Altered_WaterHeatingSystem !=  CentralNonresSpaces And  != CentralDwellingUnits 
result = BlankGrayedOut
 
End If</xsd:documentation>
                          </xsd:annotation>
                          <xsd:simpleType>
                            <xsd:restriction base="comp:NotApplicableMessage">
                              <xsd:enumeration value="BlankGrayedOut"/>
                            </xsd:restriction>
                          </xsd:simpleType>
                        </xsd:element>
                        <xsd:choice maxOccurs="1">
                          <xsd:element name="F04_ExceptionsToPrescReqsDHW" type="comp:ExceptionsToPrescReqsDHW">
                            <xsd:annotation>
                              <xsd:documentation source="FieldText">Exception to <d:t24refnolink/>140.5(c)/<d:t24refnolink/>170.2(d)2B</xsd:documentation>
                              <xsd:documentation source="CalculationsAndRules">If B02New_WaterHeatingSystem  IsPresent And  B02New_WaterHeatingSystem ==  CentralNonresSpaces Or == CentralDwellingUnits 
Or If  B02Altered_WaterHeatingSystem  IsPresent And  B02Altered_WaterHeatingSystem ==  CentralNonresSpaces Or  == CentralDwellingUnits
 
User selects from dropdown list
End If</xsd:documentation>
                            </xsd:annotation>
                          </xsd:element>
                          <xsd:element name="F04_NotApplicableMessage ">
                            <xsd:annotation>
                              <xsd:documentation source="FieldText">Exception to <d:t24refnolink/>140.5(c)/<d:t24refnolink/>170.2(d)2B</xsd:documentation>
                              <xsd:documentation source="CalculationsAndRules">If B02New_WaterHeatingSystem  IsPresent And  B02New_WaterHeatingSystem !=  CentralNonresSpaces And  != CentralDwellingUnits 
result = BlankGrayedOut
Else If B02Altered_WaterHeatingSystem  IsPresent And  B02Altered_WaterHeatingSystem !=  CentralNonresSpaces And  != CentralDwellingUnits 
result = BlankGrayedOut
 
End If</xsd:documentation>
                            </xsd:annotation>
                            <xsd:simpleType>
                              <xsd:restriction base="comp:NotApplicableMessage">
                                <xsd:enumeration value="BlankGrayedOut"/>
                              </xsd:restriction>
                            </xsd:simpleType>
                          </xsd:element>
                        </xsd:choice>
                        <xsd:choice maxOccurs="1">
                          <xsd:element name="F06_EfficiencyCapWeightedAvg" type="hvac:EfficiencyCapWeightedAvg">
                            <xsd:annotation>
                              <xsd:documentation source="FieldText">Capacity-weighted Average Efficiency %</xsd:documentation>
                              <xsd:documentation source="CalculationsAndRules"> If F04_ExceptionsToPrescReqsDHW == ExceptionsNonApply
 
Calculated field: For all rows where  F10a_WaterHeaterCapacityRated GT 100,000 And F08_WaterHeaterType == BoilerCommercialGTE1MMBtu Or BoilerResDutyCommercial Or BoilerWaterHeater Or BoilerCommercialLT1MMBtu Or InstantaneousCommercial Or StorageCommercial And F07_Status == NewOrAddition
result = (SUM (F11 Rated Efficiency for the row where F08_WaterHeaterType == BoilerCommercialGTE1MMBtu Or BoilerResDutyCommercial Or BoilerWaterHeater Or BoilerCommercialLT1MMBtu Or InstantaneousCommercial Or StorageCommercial  x  F10a_WaterHeaterCapacityRated)) /  SUM ALL ( F10a_WaterHeaterCapacityRated where F08_WaterHeaterType == BoilerCommercialGTE1MMBtu Or BoilerResDutyCommercial Or BoilerWaterHeater Or BoilerCommercialLT1MMBtu Or InstantaneousCommercial Or StorageCommercial)
End If</xsd:documentation>
                            </xsd:annotation>
                          </xsd:element>
                          <xsd:element name="F06_NotApplicableMessage ">
                            <xsd:annotation>
                              <xsd:documentation source="FieldText">Capacity-weighted Average Efficiency %</xsd:documentation>
                              <xsd:documentation source="CalculationsAndRules">If F04_ExceptionsToPrescReqsDHW != ExceptionsNonApply
Or 
If all rows F07_Status != NewOrAddition
result = BlankGrayedOut
End If</xsd:documentation>
                            </xsd:annotation>
                            <xsd:simpleType>
                              <xsd:restriction base="comp:NotApplicableMessage">
                                <xsd:enumeration value="BlankGrayedOut"/>
                              </xsd:restriction>
                            </xsd:simpleType>
                          </xsd:element>
                        </xsd:choice>
                        <xsd:choice maxOccurs="1">
                          <xsd:element name="F06_EfficiencyCapWeightedAvg" type="hvac:EfficiencyCapWeightedAvg">
                            <xsd:annotation>
                              <xsd:documentation source="FieldText">Capacity-weighted Average Efficiency %</xsd:documentation>
                              <xsd:documentation source="CalculationsAndRules"> If F05_IsEfficiencyCapWeightedAvg == true
And F04_ExceptionsToPrescReqsDHW == ExceptionsNonApply
 
Calculated field: For all rows where  F10a_WaterHeaterCapacityRated GT 100,000 And F08_WaterHeaterType == BoilerCommercialGTE1MMBtu Or BoilerResDutyCommercial Or BoilerWaterHeater Or BoilerCommercialLT1MMBtu Or InstantaneousCommercial Or StorageCommercial
result = (SUM (F11 Rated Efficiency for the row where F08_WaterHeaterType == BoilerCommercialGTE1MMBtu Or BoilerResDutyCommercial Or BoilerWaterHeater Or BoilerCommercialLT1MMBtu Or InstantaneousCommercial Or StorageCommercial  x  F10a_WaterHeaterCapacityRated)) /  SUM ALL ( F10a_WaterHeaterCapacityRated where F08_WaterHeaterType == BoilerCommercialGTE1MMBtu Or BoilerResDutyCommercial Or BoilerWaterHeater Or BoilerCommercialLT1MMBtu Or InstantaneousCommercial Or StorageCommercial)
End If</xsd:documentation>
                            </xsd:annotation>
                          </xsd:element>
                          <xsd:element name="F06_NotApplicableMessage ">
                            <xsd:annotation>
                              <xsd:documentation source="FieldText">Capacity-weighted Average Efficiency %</xsd:documentation>
                              <xsd:documentation source="CalculationsAndRules">if F05_IsEfficiencyCapWeightedAvg == false
Or F04_ExceptionsToPrescReqsDHW != ExceptionsNonApply
result = BlankGrayedOut
End If</xsd:documentation>
                            </xsd:annotation>
                            <xsd:simpleType>
                              <xsd:restriction base="comp:NotApplicableMessage">
                                <xsd:enumeration value="BlankGrayedOut"/>
                              </xsd:restriction>
                            </xsd:simpleType>
                          </xsd:element>
                        </xsd:choice>
                        <xsd:element name="TableSystemDetails">
                          <xsd:annotation>
                            <xsd:documentation source="FieldText"/>
                          </xsd:annotation>
                          <xsd:complexType>
                            <xsd:sequence>
                              <xsd:element name="Row" minOccurs="1" maxOccurs="unbounded">
                                <xsd:complexType>
                                  <xsd:sequence>
                                    <xsd:element name="F07_WaterHeaterName" type="hvac:WaterHeaterName">
                                      <xsd:annotation>
                                        <xsd:documentation source="FieldText">Name or Item Tag</xsd:documentation>
                                        <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                                      </xsd:annotation>
                                    </xsd:element>
                                    <xsd:element name="F06_WaterHeaterCount" type="hvac:WaterHeaterCount">
                                      <xsd:annotation>
                                        <xsd:documentation source="FieldText">Quantity</xsd:documentation>
                                        <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                                      </xsd:annotation>
                                    </xsd:element>
                                    <xsd:element name="F07_Status">
                                      <xsd:annotation>
                                        <xsd:documentation source="FieldText">System Status</xsd:documentation>
                                        <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                                      </xsd:annotation>
                                      <xsd:simpleType>
                                        <xsd:restriction base="hvac:Status">
                                          <xsd:enumeration value="NewOrAddition"/>
                                          <xsd:enumeration value="Alteration"/>
                                        </xsd:restriction>
                                      </xsd:simpleType>
                                    </xsd:element>
                                    <xsd:element name="F08_WaterHeaterType">
                                      <xsd:annotation>
                                        <xsd:documentation source="FieldText">Equipment Type</xsd:documentation>
                                        <xsd:documentation source="CalculationsAndRules">
If F02_WaterHeaterSpaceType == School And A03_WholeBuildingOccupancy == InRange(2,15) And A04a_ConditionedFloorArea LTE 25,000 And F07_Status == NewOrAddition
   User selects from: NEEAIndividualHeatPumpWH, NonNEEAIndividualHeatPumpWH, HeatPumpAirSource
Else 
   User selects from full list 
Mandatory Measure Triggers:  
Multi-field triggers: See B03aAltered_ProjectHasEquipment  CalculationsAndRules for trigger values from this field</xsd:documentation>
                                        <xsd:appinfo source="displayterm">
                                          <dtyp:displayterm value="CentralHeatPumpWH">NA: Central Heat Pump Water Heater (See Other Table)</dtyp:displayterm>
                                        </xsd:appinfo>
                                      </xsd:annotation>
                                      <xsd:simpleType>
                                        <xsd:restriction base="hvac:WaterHeaterType">
                                          <xsd:enumeration value="HeatPumpAirSource"/>
                                          <xsd:enumeration value="HeatPumpWaterHeater"/>
                                          <xsd:enumeration value="InstantaneousConsumer"/>
                                          <xsd:enumeration value="InstantaneousConsumerElectric"/>
                                          <xsd:enumeration value="StorageConsumer"/>
                                          <xsd:enumeration value="StorageResDutyCommercial"/>
                                          <xsd:enumeration value="NEEAIndividualHeatPumpWH"/>
                                          <xsd:enumeration value="NonNEEAIndividualHeatPumpWH"/>
                                        </xsd:restriction>
                                      </xsd:simpleType>
                                    </xsd:element>
                                    <xsd:choice maxOccurs="1">
                                      <xsd:element name="F09_WaterHeaterTankVolume" type="hvac:WaterHeaterTankVolume">
                                        <xsd:annotation>
                                          <xsd:documentation source="FieldText">Volume (gal)</xsd:documentation>
                                          <xsd:documentation source="CalculationsAndRules">If F08_WaterHeaterType == BoilerCommercialGTE1MMBtu, StorageCommercial Or StorageCommercialElectric Or BoilerWaterHeater Or BoilerCommercialLT1MMBtu Or BoilerResDutyCommercial Or InstantaneousCommercial
User enters value; which is stored in F09_WaterHeaterTankVolume 
End If</xsd:documentation>
                                        </xsd:annotation>
                                      </xsd:element>
                                      <xsd:element name="F09_WaterHeaterVolume" type="hvac:WaterHeaterVolume">
                                        <xsd:annotation>
                                          <xsd:documentation source="FieldText">Volume (gal)</xsd:documentation>
                                          <xsd:documentation source="CalculationsAndRules">If  F08_WaterHeaterType == InstantaneousConsumer Or  InstantaneousConsumerElectric Or InstantaneousResDutyCommercial Or StorageConsumer Or StorageConsumerElectric Or StorageResDutyCommercial Or TableTopElectric
User enters value; which is stored in F09_WaterHeaterVolume
End If</xsd:documentation>
                                        </xsd:annotation>
                                      </xsd:element>
                                      <xsd:element name="F09_NotApplicableMessage">
                                        <xsd:annotation>
                                          <xsd:documentation source="FieldText">Volume (gal)</xsd:documentation>
                                          <xsd:documentation source="CalculationsAndRules">If F08_WaterHeaterType == CentralHeatPumpWH or NEEAIndividualHeatPumpWH or NonNEEAIndividualHeatPumpWH
 result = BlankGrayedOut stored in NotApplicableMessage
End If</xsd:documentation>
                                        </xsd:annotation>
                                        <xsd:simpleType>
                                          <xsd:restriction base="comp:NotApplicableMessage">
                                            <xsd:enumeration value="BlankGrayedOut"/>
                                          </xsd:restriction>
                                        </xsd:simpleType>
                                      </xsd:element>
                                    </xsd:choice>
                                    <xsd:choice maxOccurs="1">
                                      <xsd:element name="F10a_WaterHeaterCapacityRated" type="hvac:WaterHeaterCapacityRated">
                                        <xsd:annotation>
                                          <xsd:documentation source="FieldText">Rated Input Capacity (Btu/h)</xsd:documentation>
                                          <xsd:documentation source="CalculationsAndRules">If F08_WaterHeaterType ==   BoilerCommercialGTE1MMBtu or BoilerResDutyCommercial or BoilerWaterHeater or BoilerCommercialLT1MMBtu or InstantaneousCommercial or InstantaneousConsumer or StorageCommercial or StorageConsumer or StorageResDutyCommercial: 
User input
End If</xsd:documentation>
                                        </xsd:annotation>
                                      </xsd:element>
                                      <xsd:element name="F10a_NotApplicableMessage">
                                        <xsd:annotation>
                                          <xsd:documentation source="FieldText">Rated Input Capacity (Btu/h) or</xsd:documentation>
                                          <xsd:documentation source="CalculationsAndRules"> If F08_WaterHeaterType == CentralHeatPumpWH or InstantaneousConsumerElectric or InstantaneousResDutyCommercial or StorageCommercialElectric or StorageConsumerElectric or TableTopElectric or NEEAIndividualHeatPumpWH or NonNEEAIndividualHeatPumpWH:
result = BlankGrayedOut stored in NotApplicableMessage
End If</xsd:documentation>
                                        </xsd:annotation>
                                        <xsd:simpleType>
                                          <xsd:restriction base="comp:NotApplicableMessage">
                                            <xsd:enumeration value="BlankGrayedOut"/>
                                          </xsd:restriction>
                                        </xsd:simpleType>
                                      </xsd:element>
                                    </xsd:choice>
                                    <xsd:choice maxOccurs="1">
                                      <xsd:element name="F11_ThermalEfficiency" type="hvac:ThermalEfficiency">
                                        <xsd:annotation>
                                          <xsd:documentation source="FieldText">Rated Efficiency</xsd:documentation>
                                          <xsd:documentation source="CalculationsAndRules">If F08_WaterHeaterType == StorageCommercial Or InstantaneousCommercial Or BoilerWaterHeater Or BoilerCommercialLT1MMBtu Or BoilerCommercialGTE1MMBtu 
User enters Thermal Efficiency value
End If</xsd:documentation>
                                        </xsd:annotation>
                                      </xsd:element>
                                      <xsd:element name="F11_UniformEnergyFactor" type="hvac:UniformEnergyFactor">
                                        <xsd:annotation>
                                          <xsd:documentation source="FieldText">Rated Efficiency</xsd:documentation>
                                          <xsd:documentation source="CalculationsAndRules">If F08_WaterHeaterType == InstantaneousConsumer,  InstantaneousConsumerElectric, StorageConsumer, StorageConsumerElectric Or TableTopElectric Or InstantaneousResDutyCommercial Or StorageResDutyCommercial
User enters UEF efficiency</xsd:documentation>
                                        </xsd:annotation>
                                      </xsd:element>
                                      <xsd:element name="F11_EfficiencyAFUE" type="hvac:EfficiencyAFUE">
                                        <xsd:annotation>
                                          <xsd:documentation source="FieldText">Rated Efficiency</xsd:documentation>
                                          <xsd:documentation source="CalculationsAndRules">If F08_WaterHeaterType == BoilerResDutyCommercial, user enters AFUE value.</xsd:documentation>
                                        </xsd:annotation>
                                      </xsd:element>
                                      <xsd:element name="F11_NotApplicableMessage">
                                        <xsd:annotation>
                                          <xsd:documentation source="FieldText">Rated Efficiency</xsd:documentation>
                                          <xsd:documentation source="CalculationsAndRules">If F08_WaterHeaterType == CentralHeatPumpWH or NEEAIndividualHeatPumpWH or NonNEEAIndividualHeatPumpWH Or StorageCommercialElectric
result = BlankGrayedOut stored in NotApplicableMessage
End If</xsd:documentation>
                                        </xsd:annotation>
                                        <xsd:simpleType>
                                          <xsd:restriction base="comp:NotApplicableMessage">
                                            <xsd:enumeration value="BlankGrayedOut"/>
                                          </xsd:restriction>
                                        </xsd:simpleType>
                                      </xsd:element>
                                    </xsd:choice>
                                    <xsd:element name="F12_FederalMinEfficiency" type="comp:FederalMinEfficiency">
                                      <xsd:annotation>
                                        <xsd:documentation source="FieldText">Minimum Efficiency Required</xsd:documentation>
                                        <xsd:documentation source="CalculationsAndRules"> Result = MinEfficiency </xsd:documentation>
                                      </xsd:annotation>
                                    </xsd:element>
                                    <xsd:element name="F13_FederalMinEfficiency" type="comp:FederalMinEfficiency">
                                      <xsd:annotation>
                                        <xsd:documentation source="FieldText">Maximum Standby Loss</xsd:documentation>
                                        <xsd:documentation source="CalculationsAndRules">Result = IfApplicable</xsd:documentation>
                                      </xsd:annotation>
                                    </xsd:element>
                                  </xsd:sequence>
                                </xsd:complexType>
                              </xsd:element>
                            </xsd:sequence>
                          </xsd:complexType>
                        </xsd:element>
                      </xsd:sequence>
                    </xsd:complexType>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
            <xsd:element name="FEndNote1" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation source="FieldText"/>
                <xsd:documentation source="AdditionalRequirements">

                <xsd:documentation source="FieldText">
                  <d:b>TABLE 160.4-A PIPE INSULATION THICKNESS</d:b>
                </xsd:documentation>
                <xsd:documentation source="CalculationsAndRules">This subsection is displayed but no data is required in the XML file as all fields have only one value allowed for display purposes</xsd:documentation>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="Gpit01_PipeFluidTempRange" minOccurs="0">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Fluid Temperature Range (<d:deg/>F)</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">This is a static field not required in the XML data but if displayed should always display the restricted value display term 105-140</xsd:documentation>

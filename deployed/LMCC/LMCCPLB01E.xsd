                    </xsd:simpleType>
                  </xsd:element>
                  <xsd:element name="Gpit06a_PipeNominalDiameter" minOccurs="0">
                    <xsd:annotation>
                      <xsd:documentation source="FieldText">Nominal Pipe Diameter (in)</xsd:documentation>
                      <xsd:documentation source="CalculationsAndRules">This is a static field not required in the XML data but if displayed should always display the restricted value display term 1.5 to <d:lt/>4</xsd:documentation>
                    </xsd:annotation>
                    <xsd:simpleType>
                      <xsd:restriction base="hvac:PipeNominalDiameter">

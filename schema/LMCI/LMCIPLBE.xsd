<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema
   targetNamespace="http://www.lmonte.com/besm/LMCIPLBE"
   xmlns="http://www.lmonte.com/besm/LMCIPLBE"
   xmlns:d="http://www.lmonte.com/besm/d"
   xmlns:bld="http://www.lmonte.com/besm/bld"
   xmlns:env="http://www.lmonte.com/besm/env"
   xmlns:lit="http://www.lmonte.com/besm/lit"
   xmlns:hvac="http://www.lmonte.com/besm/hvac"
   xmlns:comp="http://www.lmonte.com/besm/comp"
   xmlns:com="http://www.lmonte.com/besm/com"
   xmlns:dtyp="http://www.lmonte.com/besm/dtyp"
   xmlns:xsd="http://www.w3.org/2001/XMLSchema"
   xmlns:altova="http://www.altova.com/xml-schema-extensions"
   elementFormDefault="qualified" attributeFormDefault="unqualified" version="2025.0.000">
   <xsd:import namespace="http://www.lmonte.com/besm/com" schemaLocation="../base/ResCommon.xsd"/>
   <xsd:import namespace="http://www.lmonte.com/besm/bld" schemaLocation="../base/ResBuilding.xsd"/>
   <xsd:import namespace="http://www.lmonte.com/besm/env" schemaLocation="../base/ResEnvelope.xsd"/>
   <xsd:import namespace="http://www.lmonte.com/besm/lit" schemaLocation="../base/ResLighting.xsd"/>
   <xsd:import namespace="http://www.lmonte.com/besm/hvac" schemaLocation="../base/ResHvac.xsd"/>
   <xsd:import namespace="http://www.lmonte.com/besm/comp" schemaLocation="../base/ResCompliance.xsd"/>
   <xsd:import namespace="http://www.lmonte.com/besm/dtyp" schemaLocation="../base/DataTypes.xsd"/>
   <xsd:element name="ComplianceDocumentPackage">
      <xsd:complexType>
         <xsd:sequence>
            <xsd:element name="DocID" minOccurs="0">
               <xsd:complexType>
                  <xsd:attribute name="doc" type="comp:ComplianceDocumentTag" fixed="LMCIPLBE"/>
                  <xsd:attribute name="docType" type="comp:ComplianceDocumentType" fixed="CERTIFICATE OF INSTALLATION"/>
                  <xsd:attribute name="docTitle" type="comp:ComplianceDocumentTitleRes" fixed="Domestic Water Heating System"/>
               </xsd:complexType>
            </xsd:element>
            <xsd:element name="Payload" type="comp:Payload"/>
            <xsd:element name="DocumentData">
               <xsd:complexType>
                  <xsd:sequence>
                     <xsd:element name="Header" type="comp:HeaderHERS" />
                     <xsd:element ref="lMCIPLBE" />
                     <xsd:element name="DocAuthor" type="comp:DocumentAuthor" />
                     <xsd:element name="RespPerson" type="comp:ResponsiblePersonCF2R_H" maxOccurs="unbounded"/>
                     <xsd:element name="Footer" type="comp:Footer" />
                     <xsd:element name="ComplianceID" minOccurs="0"/>
                  </xsd:sequence>
               </xsd:complexType>
            </xsd:element>
            <xsd:element name="Report" type="xsd:base64Binary"/>
            <xsd:element name="ReportMMB" type="xsd:base64Binary" minOccurs="0"/>
         </xsd:sequence>
         <xsd:attribute name="revision" use="required" type="xsd:string" fixed="rev 20250901"/>
         <xsd:attribute name="doc" use="required" type="comp:ComplianceDocumentTag" fixed="LMCIPLBE"/>
      </xsd:complexType>
   </xsd:element>
   <xsd:complexType name="LMCIPLBE">
      <xsd:annotation>
         <xsd:documentation>Domestic Water Heating System</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="Section_A" minOccurs="1" maxOccurs="1">
            <xsd:annotation>
               <xsd:documentation source="FieldText">[d:b]A. GENERAL INFORMATION[/d:b]</xsd:documentation>
               <xsd:documentation source="MinOccurs">This section is required.</xsd:documentation>
            </xsd:annotation>
            <xsd:complexType>
               <xsd:sequence>
                  <xsd:element name="A_BeforeNote1" minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"></xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">[d:i]This  Certificate of Installation documents the installation of service water heating features, materials, components, and manufactured devices required to demonstrate compliance with Title 24, Part 6 per [d:t24refnolink/]110-103(a)3 for nonresidential spaces with water heating systems in low-rise mixed-use buildings. Low-rise multifamily buildings which are not mixed-use should document water heating systems on theLMCI-PLB-01-E for Central Water Heating systems in Dwelling Units and the LMCI-PLB-02-E for Single Dwelling Unit Water Heating Systems through HERS Providers Registries.[/d:i]</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="A01_ProjectCity" type="comp:ProjectCity" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Project Location (city)</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">If NRCC-PLB parent
result = A01_ProjectCity
Else If NRCC-PRF parent
result = Info01_ProjectCity
End If</xsd:documentation>
                        <xsd:appinfo source="CIsrc">
                           <dtyp:srcSchema form="CCPLB01E"  usage="copy">A01_ProjectCity</dtyp:srcSchema>
                           <dtyp:srcSchema form="CCPRF01E"  usage="copy">Info04_ProjectCity</dtyp:srcSchema>
                        </xsd:appinfo>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="A02_ProjectZipcode" type="comp:ProjectZipcode" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Zip Code</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">If NRCC-PLB parent
User input
Else If NRCC-PRF parent
result = Info02_ProjectZipcode
End If</xsd:documentation>
                        <xsd:appinfo source="CIsrc">
                           <dtyp:srcSchema form="CCPRF01E"  usage="copy">Info06_ProjectZipcode</dtyp:srcSchema>
                        </xsd:appinfo>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="A03_PermitSetDate" type="comp:PermitSetDate" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Date of Permit Set used for construction</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="A04_AuthorityHavingJurisdiction" type="comp:AuthorityHavingJurisdiction" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Authority Having Jurisdiction</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="A05_PermitNumber" type="comp:PermitNumber" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Building Permit #</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="A06_AsBuiltSetDate" type="comp:AsBuiltSetDate" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Date of As-built Set</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="A07_PermitSetName" type="comp:PermitSetName"  minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">NOT REPORTED IN PDF</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">Name of Permit Set used for construction</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">This data is not currently required but may be needed in the future</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="A08_AsBuiltSetName" type="comp:AsBuiltSetName"  minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">NOT REPORTED IN PDF</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">Name of As-built Set</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">This data is not currently required but may be needed in the future</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
               </xsd:sequence>
            </xsd:complexType>
         </xsd:element>
         <xsd:element name="Section_B" minOccurs="1" maxOccurs="1">
            <xsd:annotation>
               <xsd:documentation source="FieldText">[d:b] B. INSTALLER SCOPE[/d:b]</xsd:documentation>
               <xsd:documentation source="MinOccurs">This section is required.</xsd:documentation>
            </xsd:annotation>
            <xsd:complexType>
               <xsd:sequence>
                  <xsd:element name="B_BeginNote1" minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"></xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">[d:i]This table indicates construction systems and materials documented on this Certificate of Installation.[/d:i]</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="B01_ProjectHasEquipment" type="comp:ProjectHasEquipment" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Equipment</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">User input;  This includes new and altered equipment</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="B02_ProjectHasDistribution" type="comp:ProjectHasDistribution" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Distribution (Piping, valves, insulation, etc)</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">User input; This includes new and altered distribution</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="B03_ProjectHasControls" type="comp:ProjectHasControls" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Controls</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">User input; This includes new and altered controls</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="B04_ProjectHasPoolSpa" type="comp:ProjectHasPoolSpa" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Controls</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
               </xsd:sequence>
            </xsd:complexType>
         </xsd:element>
         <xsd:element name="Section_C" minOccurs="1">
            <xsd:annotation>
               <xsd:documentation source="FieldText">[d:b]C. COMPLIANCE RESULTS[/d:b]</xsd:documentation>
               <xsd:documentation source="MinOccurs">This section is required.</xsd:documentation>
            </xsd:annotation>
            <xsd:complexType>
               <xsd:sequence>
                  <xsd:element name="C_BeginNote1" minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"></xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">[d:i]This table indicates whether the as-built conditions documented in this form are equal or better than what was documented on the permitted Certificate of Compliance.  If the installation is not equal or better, Section 10-103(a)2B requires the Certificate of Compliance form to be revised accordingly to demonstrate compliance.[/d:i]</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="C01_ComplianceResultCI" type="comp:ComplianceResultCI" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"></xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">Calculated result:  
If in any required tables or subsections in Section F  ComplianceResultCI ==  TableIncomplete
result = FormNotComplete
Else If in any required tables or subsections in Section F ComplianceResultCI == MayNotComply
result = MayNotComply
Else If All required tables or subsections in Section F  have  ComplianceResultCI ==  ExactMatch
result = ExactMatch
Else If any required tables or subsections in Section F have ComplianceResultCI ==  EqualBetter
result = EqualBetter
End If</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="C01Message_ComplianceResultMessageCI" type="comp:ComplianceResultMessageCI" >
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"></xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">Calculated result:  
If C01_ComplianceResultCI == ExactMatch Or EqualBetter
result = ExactEqualBetterText
Else If C01_ComplianceResultCI == MayNotComply
result =  MayNotComplyText
End If</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
               </xsd:sequence>
            </xsd:complexType>
         </xsd:element>
         <xsd:element name="Section_D" minOccurs="1">
            <xsd:annotation>
               <xsd:documentation source="FieldText">[d:b]D. EXCEPTIONAL CONDITIONS[/d:b]</xsd:documentation>
               <xsd:documentation source="MinOccurs">This section is required.</xsd:documentation>
            </xsd:annotation>
            <xsd:complexType>
               <xsd:sequence>
                  <xsd:element name="D_BeginNote1" minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"></xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">[d:i]This table is auto-filled with uneditable comments because of field conditions noted by the installer that may impact requirements documented on the Certificate of Compliance.[/d:i]</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="D01_ExceptionalConditionMessageCIPLBE" type="comp:ExceptionalConditionMessageCIPLBE"  minOccurs="0" maxOccurs="unbounded">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Exceptional Messages</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">Auto-filled with any system generated messages that explain exceptional conditions encountered in the the completed compliance document
If ExceptionalConditionMessageNRCIPLBE == ""
result = NoExceptionNote
End If</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
               </xsd:sequence>
            </xsd:complexType>
         </xsd:element>
         <xsd:element name="Section_E" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation source="FieldText">[d:b]E. INSTALLER NOTES[/d:b]</xsd:documentation>
               <xsd:documentation source="CalculationsAndRules">This section is required if there are  comments from the permit applicant to the Authority Having Jurisdiction</xsd:documentation>
               <xsd:documentation source="MinOccurs">If this section doesn't apply, do not display anything for this section</xsd:documentation>
            </xsd:annotation>
            <xsd:complexType>
               <xsd:sequence>
                  <xsd:element name="E_BeginNote1" minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"></xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">[d:i]This table includes remarks made by the installer to the Authority Having Jurisdiction.[/d:i]</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="E01_CommentsToPermitAuthority" type="comp:CommentsToPermitAuthority"  minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"></xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
               </xsd:sequence>
            </xsd:complexType>
         </xsd:element>
         <xsd:element name="Section_F" minOccurs="1">
            <xsd:annotation>
               <xsd:documentation source="FieldText">[d:b]F. INSTALLATION DETAILS [/d:b]</xsd:documentation>
               <xsd:documentation source="MinOccurs">This section is required.</xsd:documentation>
            </xsd:annotation>
            <xsd:complexType>
               <xsd:sequence>
                  <xsd:element name="F_BeginNote1" minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"></xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">[d:i]The following tables indicate performance requirements as documented on the permitted Certificate of Compliance (NRCC) for all systems and components included in Table B. Installer Scope.  Also included are the as-built conditions documented by the installer/documentation author. [/d:i]</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="F_RowLabelTopCell" minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Per C of C</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">This is the text displayed at the left end of a row in the top cell for all tables/subsections in Section F except the last subsection Smart Thermostats and Additional Efficiency Measure</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="F_RowLabelBottomCell" minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">As-built Conditions</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">This is the text displayed at the left end of a row in the bottom cell for all tables/subsections in Section F except the last subsection Smart Thermostats and Additional Efficiency Measure</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="DHW" minOccurs="0">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"></xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">This subsection is required If B01_ProjectHasEquipment == true</xsd:documentation>
                     </xsd:annotation>
                     <xsd:complexType>
                        <xsd:sequence>
                           <xsd:element name="TableDHW" >
                              <xsd:annotation>
                                 <xsd:documentation source="FieldText">[d:b]Domestic Hot Water Equipment Efficiency[/d:b]</xsd:documentation>
                              </xsd:annotation>
                              <xsd:complexType>
                                 <xsd:sequence>
                                    <xsd:element name="Row" minOccurs="1" maxOccurs="unbounded">
                                       <xsd:complexType>
                                          <xsd:sequence>
                                             <xsd:element name="DHW01cc_WaterHeaterName" type="hvac:WaterHeaterName" >
                                                <xsd:annotation>
                                                   <xsd:documentation source="FieldText">Name or Item Tag</xsd:documentation>
                                                   <xsd:documentation source="CalculationsAndRules">
If NRCC-PLB parent
   result = F07_WaterHeaterName
Else If NRCC-PRF parent
   If WaterMF01_WaterHeatingSystemName
      result = WaterMF01_WaterHeatingSystemName
   Else If Water01_WaterHeaterName IsPresent
      result = Water01_WaterHeaterName
   End If
End If</xsd:documentation>
                                                   <xsd:appinfo source="CIsrc">
                                                      <dtyp:srcSchema form="CCPLB01E"  usage="copy">F07_WaterHeaterName</dtyp:srcSchema>
                                                      <dtyp:srcSchema form="CCPRF01E"  usage="copy">Water01_WaterHeaterName</dtyp:srcSchema>
                                                      <dtyp:srcSchema form="CCPRF01E"  usage="copy">WaterMF01_WaterHeatingSystemName</dtyp:srcSchema>
                                                   </xsd:appinfo>
                                                </xsd:annotation>
                                             </xsd:element>
                                             <xsd:element name="DHW01_InMyScope" type="comp:InMyScope" >
                                                <xsd:annotation>
                                                   <xsd:documentation source="FieldText">Is this in your scope?</xsd:documentation>
                                                   <xsd:documentation source="CalculationsAndRules">User selects from true value display term Yes and false value display term No, by others
 If result == false DHW02cc-DHW10cc and DHW02-DHW10 As-built fields are blank and grayed out
And D01_ExceptionalConditionMessageNRCIPLBE += DHWNotInScope  
End If</xsd:documentation>
                                                </xsd:annotation>
                                             </xsd:element>
                                             <xsd:element name="DHWScopeChoice" >
                                                <xsd:annotation>
                                                   <xsd:documentation source="FieldText"></xsd:documentation>
                                                </xsd:annotation>
                                                <xsd:complexType>
                                                   <xsd:choice >
                                                      <xsd:element name="DHWScopeNA_NotApplicableMessage" >
                                                         <xsd:annotation>
                                                            <xsd:documentation source="FieldText"></xsd:documentation>
                                                            <xsd:documentation source="CalculationsAndRules">If DHW01_InMyScope == false
result = BlankGrayedOut for DHW02cc-DHW10 cc and DHW02-DHW10 As-built fields are blank and grayed out 
End If</xsd:documentation>
                                                         </xsd:annotation>
                                                         <xsd:simpleType>
                                                            <xsd:restriction base="comp:NotApplicableMessage">
                                                               <xsd:enumeration value="BlankGrayedOut"/>
                                                            </xsd:restriction>
                                                         </xsd:simpleType>
                                                      </xsd:element>
                                                      <xsd:element name="DHWInScope" >
                                                         <xsd:annotation>
                                                            <xsd:documentation source="FieldText"></xsd:documentation>
                                                         </xsd:annotation>
                                                         <xsd:complexType>
                                                            <xsd:sequence>
                                                               <xsd:element name="DHW01_InstalledSameAsCC" type="comp:InstalledSameAsCC"  minOccurs="0">
                                                                  <xsd:annotation>
                                                                     <xsd:documentation source="FieldText">NOT REPORTED IN PDF</xsd:documentation>
                                                                     <xsd:documentation source="CalculationsAndRules">User selects true if installed is the same as CC value  Or false if installed is different than CC value</xsd:documentation>
                                                                  </xsd:annotation>
                                                               </xsd:element>
                                                               <xsd:element name="DHW02cc_NotApplicableMessage" >
                                                                  <xsd:annotation>
                                                                     <xsd:documentation source="FieldText">Model #</xsd:documentation>
                                                                     <xsd:documentation source="CalculationsAndRules">The CC cell is always BlankGrayedOut</xsd:documentation>
                                                                  </xsd:annotation>
                                                                  <xsd:simpleType>
                                                                     <xsd:restriction base="comp:NotApplicableMessage">
                                                                        <xsd:enumeration value="BlankGrayedOut"/>
                                                                     </xsd:restriction>
                                                                  </xsd:simpleType>
                                                               </xsd:element>
                                                               <xsd:element name="DHW02a_ModelNumber" type="hvac:ModelNumber" >
                                                                  <xsd:annotation>
                                                                     <xsd:documentation source="FieldText">Model #</xsd:documentation>
                                                                     <xsd:documentation source="CalculationsAndRules">User input</xsd:documentation>
                                                                  </xsd:annotation>
                                                               </xsd:element>
                                                               <xsd:element name="DHW03cc_CentralSystem">
                                                                  <xsd:annotation>
                                                                     <xsd:documentation source="FieldText">Space Type</xsd:documentation>
                                                                     <xsd:documentation source="CalculationsAndRules">
If CC-PLB parent
   If F08_WaterHeaterType == InstantaneousConsumer Or StorageConsumer Or StorageResDutyCommercial Or InstantaneousConsumerElectric Or InstantaneousResDutyCommercial Or StorageConsumerElectric Or NonNEEAIndividualHeatPumpWH Or NEEAIndividualHeatPumpWH Or TableTopElectric
      result = false
   Else 
      result = true
Else If CC-PRF parent
   If WaterMF03_CentralSystem IsPresent
      result = WaterMF03_CentralSystem
   Else
      result = BlankGrayedOut
End If</xsd:documentation>
                                                                     <xsd:appinfo source="displayterm">
                                                                        <dtyp:displayterm value="true">Central</dtyp:displayterm>
                                                                        <dtyp:displayterm value="false">Individual</dtyp:displayterm>
                                                                     </xsd:appinfo>
                                                                     
                                                                     <xsd:appinfo source="CIsrc">
                                                                        <dtyp:srcSchema form="CCPLB01E"  usage="reference">F08_WaterHeaterType</dtyp:srcSchema>
                                                                        <dtyp:srcSchema form="CCPRF01E"  usage="reference">WaterMF03_CentralSystem</dtyp:srcSchema>
                                                                     </xsd:appinfo>
                                                                  </xsd:annotation>
                                                                  <xsd:simpleType>
                                                                     <xsd:union memberTypes="hvac:CentralSystem comp:NotApplicableMessage"/>
                                                                  </xsd:simpleType>
                                                               </xsd:element>
                                                               <xsd:element name="DHW03_CentralSystem">
                                                                  <xsd:annotation>
                                                                     <xsd:documentation source="FieldText">Space Type</xsd:documentation>
                                                                     <xsd:documentation source="CalculationsAndRules">If DHW01_InstalledSameAsCC == true
result = DHW03cc_CentralSystem
Else
User input
End If</xsd:documentation>
                                                                     <xsd:appinfo source="displayterm">
                                                                        <dtyp:displayterm value="true">Central</dtyp:displayterm>
                                                                        <dtyp:displayterm value="false">Individual</dtyp:displayterm>
                                                                     </xsd:appinfo>
                                                                     
                                                                  </xsd:annotation>
                                                                  <xsd:simpleType>
                                                                     <xsd:union memberTypes="hvac:CentralSystem comp:NotApplicableMessage"/>
                                                                  </xsd:simpleType>
                                                               </xsd:element>
                                                               <xsd:choice maxOccurs="1">
                                                                  <xsd:element name="DHW04cc_WaterHeaterType" type="hvac:WaterHeaterType" >
                                                                     <xsd:annotation>
                                                                        <xsd:documentation source="FieldText">Equipment Type</xsd:documentation>
                                                                        <xsd:documentation source="CalculationsAndRules">If CC-PLB parent
result = F08_WaterHeaterType
End If</xsd:documentation>
                                                                        
                                                                        <xsd:appinfo source="CIsrc">
                                                                           <dtyp:srcSchema form="CCPLB01E"  usage="copy">F08_WaterHeaterType</dtyp:srcSchema>
                                                                        </xsd:appinfo>
                                                                     </xsd:annotation>
                                                                  </xsd:element>
                                                                  <xsd:element name="DHW04cc_TankCategory" type="hvac:TankCategory" >
                                                                     <xsd:annotation>
                                                                        <xsd:documentation source="FieldText">Equipment Type</xsd:documentation>
                                                                        <xsd:documentation source="CalculationsAndRules">If CC-PRF parent
If Water03_TankCategory IsPresent
result = Water03_TankCategory
End If
End If</xsd:documentation>
                                                                        <xsd:appinfo source="CIsrc">
                                                                           <dtyp:srcSchema form="CCPRF01E"  usage="copy">Water03_TankCategory</dtyp:srcSchema>
                                                                        </xsd:appinfo>
                                                                     </xsd:annotation>
                                                                  </xsd:element>
                                                                  <xsd:element name="DHW04cc_NotApplicableMessage" >
                                                                     <xsd:annotation>
                                                                        <xsd:documentation source="FieldText">Equipment Type</xsd:documentation>
                                                                        <xsd:documentation source="CalculationsAndRules">If CC-PRF parent 
If Water03_TankCategory IsNotPresent
   result = BlankGrayedOut
End If
End If</xsd:documentation>
                                                                        <xsd:appinfo source="CIsrc">
                                                                           <dtyp:srcSchema form="CCPRF01E"  usage="reference">Water03_TankCategory</dtyp:srcSchema>
                                                                        </xsd:appinfo>
                                                                     </xsd:annotation>
                                                                     <xsd:simpleType>
                                                                        <xsd:restriction base="comp:NotApplicableMessage">
                                                                           <xsd:enumeration value="BlankGrayedOut"/>
                                                                        </xsd:restriction>
                                                                     </xsd:simpleType>
                                                                  </xsd:element>
                                                               </xsd:choice>
                                                               <xsd:choice maxOccurs="1">
                                                                  <xsd:element name="DHW04_WaterHeaterType" type="hvac:WaterHeaterType" >
                                                                     <xsd:annotation>
                                                                        <xsd:documentation source="FieldText">Equipment Type</xsd:documentation>
                                                                        <xsd:documentation source="CalculationsAndRules">
If DHW04cc_WaterHeaterType IsPresent

                                                   <xsd:documentation source="CalculationsAndRules">If any user input field is blank
result = TableIncomplete  
 Else If DHW01_InMyScope == false 
result = NotInScope
 
Else If   
DHW04_WaterHeaterType IsPresent And != DHW04cc_WaterHeaterType 
Or DHW04_TankCategory IsPresent And  != DHW04cc_TankCategory
 
Or
(
DHW08_EfficiencyAFUE IsPresent And DHW08_EfficiencyAFUE LT DHW08cc_EfficiencyAFUE Or 
DHW08_EfficiencyCOP IsPresent And DHW08_EfficiencyCOP LT DHW08cc_EfficiencyCOP Or 
DHW08_ThermalEfficiency IsPresent And DHW08_ThermalEfficiency LT DHW08cc_ThermalEfficiency Or
DHW08_UniformEnergyFactor IsPresent And DHW08_UniformEnergyFactor LT DHW08cc_UniformEnergyFactor Or
DHW08_EnergyFactor IsPresent And DHW08_EnergyFactor LT DHW08cc_EnergyFactor
)
Or
(
DHW10_StandbyLoss IsPresent And DHW10_StandbyLoss GT DHW10cc_StandbyLoss Or
DHW10_WaterHeaterStandbyLossFraction IsPresent And DHW10_WaterHeaterStandbyLossFraction GT DHW10cc_WaterHeaterStandbyLossFraction
